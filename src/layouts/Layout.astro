---
import "../styles/globals.css";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer";
import FloatingActions from "../components/FloatingActions";
import { ClientRouter, slide } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Mir Diagnostics Pampore offers blood tests, health packages, home sample collection, and USG imaging services in Pampore, Kashmir.",
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = "https://mirdiagnostics.in";
const canonicalUrl = `${siteUrl}${Astro.url.pathname === "/" ? "/" : Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{title}</title>

    <meta name="robots" content="index, follow" />
    <meta name="author" content="Mir Diagnostics" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mir Diagnostics" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MedicalBusiness",
        name: "Mir Diagnostics",
        url: siteUrl,
        image: `${siteUrl}/og-image.jpg`,
        telephone: "+917006087182",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Khrew Bus Stop, Namblabal",
          addressLocality: "Pampore",
          addressRegion: "Jammu and Kashmir",
          postalCode: "192121",
          addressCountry: "IN",
        },
        areaServed: ["Pampore", "Khrew", "Namblabal"],
      })}
    />
  </head>

  <body>
    <Navbar currentPath={currentPath} client:load />

    <main transition:animate={slide({ duration: "0.5s" })} class="mt-28">
      <slot />
    </main>

    <Footer client:load />
    <FloatingActions client:load />
    <ClientRouter />
  </body>
</html>
