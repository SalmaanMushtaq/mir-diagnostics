---
import Layout from "../layouts/Layout.astro";
import { PhoneCall } from "lucide-react";
---

<Layout
  title="Contact Us"
  description="Get in touch with Mir Diagnostics – book appointments, find our location, and reach our team in Srinagar, Kashmir."
>
  <!-- Hero -->
  <div
    class="pt-20 text-white"
    style="background: linear-gradient(135deg, var(--color-lab-green) 0%, #074d25 50%, var(--color-lab-teal) 100%)"
  >
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
      <span class="font-mono text-white/60 text-sm tracking-widest uppercase"
        >— Get In Touch</span
      >
      <h1 class="font-heading text-5xl md:text-6xl font-bold mt-3 mb-4">
        Contact Us
      </h1>
      <p class="text-white/75 text-xl max-w-2xl">
        Book an appointment, ask a question, or find us on the map. We're here
        to help.
      </p>
    </div>
  </div>

  <!-- Contact Grid -->
  <section class="section-padding">
    <div class="container-tight">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Contact Info -->
        <div class="lg:col-span-1 space-y-5">
          <h2 class="font-heading text-2xl font-bold text-lab-blue mb-6">
            Reach Us
          </h2>

          {
            [
              {
                icon: `<path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"/>`,
                label: "Address",
                value: "Khrew Bus Stop, Namblabal, Pampore, J&K — 192121",
              },
              {
                icon: `<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round"/>`,
                label: "Phone",
                value: "7006087182 / 9055998899",
              },
              {
                icon: `<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>`,
                label: "Email",
                value: "mirdiagnowtics256@gmail.com",
              },
              {
                icon: `<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>`,
                label: "Hours",
                value: "Mon–Sat: 7:00 AM – 8:00 PM\nSunday: 8:00 AM – 2:00 PM",
              },
            ].map((item) => (
              <div class="flex items-start gap-4 p-4 bg-lab-light rounded-xl border border-border">
                <div class="w-10 h-10 rounded-lg bg-lab-teal/10 flex items-center justify-center shrink-0">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    class="w-5 h-5 text-lab-teal"
                    set:html={item.icon}
                  />
                </div>
                <div>
                  <div class="text-xs font-mono text-muted-foreground uppercase tracking-wider mb-1">
                    {item.label}
                  </div>
                  <div class="text-sm font-medium text-foreground whitespace-pre-line">
                    {item.value}
                  </div>
                </div>
              </div>
            ))
          }

          <!-- Emergency -->
          <div class="bg-red-50 border border-red-200 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"
              ></span>
              <span class="text-red-600 font-semibold text-sm"
                >Emergency / Urgent Tests</span
              >
            </div>
            <p class="text-red-600/80 text-sm">
              For urgent sample processing, call our emergency line: <strong
                >+91 7006087182</strong
              >
            </p>
          </div>
        </div>

        <!-- Appointment Form -->
        <div
          class="lg:col-span-2 bg-white rounded-2xl border border-border p-8 shadow-sm"
        >
          <h2 class="font-heading text-2xl font-bold text-lab-blue mb-2">
            Book an Appointment
          </h2>
          <p class="text-muted-foreground text-sm mb-7">
            Fill in the form below and our team will confirm your appointment
            within a few hours.
          </p>

          <form class="space-y-5" id="appt-form">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label
                  class="block text-sm font-medium text-foreground mb-1.5"
                  for="fname">First Name *</label
                >
                <input
                  id="fname"
                  name="fname"
                  type="text"
                  required
                  placeholder="Mohammad"
                  class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors"
                />
              </div>
              <div>
                <label
                  class="block text-sm font-medium text-foreground mb-1.5"
                  for="lname">Last Name *</label
                >
                <input
                  id="lname"
                  name="lname"
                  type="text"
                  required
                  placeholder="Mir"
                  class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label
                  class="block text-sm font-medium text-foreground mb-1.5"
                  for="phone">Phone Number *</label
                >
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  required
                  placeholder="+91 98000 00000"
                  class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors"
                />
              </div>
              <div>
                <label
                  class="block text-sm font-medium text-foreground mb-1.5"
                  for="email">Email Address</label
                >
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="you@example.com"
                  class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label
                  class="block text-sm font-medium text-foreground mb-1.5"
                  for="service">Service Required *</label
                >
                <select
                  id="service"
                  name="service"
                  required
                  class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors"
                >
                  <option value="">Select a service</option>
                  <option>Blood Test / Pathology</option>
                  <option>Ultrasound (USG)</option>
                  <option>Color Doppler</option>
                  <option>Obstetric Scan</option>
                  <option>Health Package</option>
                  <option>Home Sample Collection</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label
                  class="block text-sm font-medium text-foreground mb-1.5"
                  for="date">Preferred Date *</label
                >
                <input
                  id="date"
                  name="date"
                  type="date"
                  required
                  class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors"
                />
              </div>
            </div>

            <div>
              <label
                class="block text-sm font-medium text-foreground mb-1.5"
                for="time">Preferred Time Slot</label
              >
              <div class="flex flex-wrap gap-3" id="time-slots">
                {
                  [
                    "7:00 AM",
                    "9:00 AM",
                    "11:00 AM",
                    "1:00 PM",
                    "3:00 PM",
                    "5:00 PM",
                  ].map((t) => (
                    <label class="flex items-center gap-2 cursor-pointer group">
                      <input
                        type="radio"
                        name="time"
                        value={t}
                        class="accent-lab-teal"
                      />
                      <span class="text-sm text-muted-foreground group-hover:text-lab-teal transition-colors">
                        {t}
                      </span>
                    </label>
                  ))
                }
              </div>
            </div>

            <div>
              <label
                class="block text-sm font-medium text-foreground mb-1.5"
                for="notes">Additional Notes</label
              >
              <textarea
                id="notes"
                name="notes"
                rows={3}
                placeholder="Any specific tests required, referral doctor, or special instructions..."
                class="w-full px-4 py-2.5 rounded-lg border border-input bg-background text-sm focus:outline-none focus:ring-2 focus:ring-lab-teal/50 focus:border-lab-teal transition-colors resize-none"
              ></textarea>
            </div>

            <div class="flex items-center gap-3 pt-2">
              <!-- WhatsApp + Call buttons -->
              <div class="flex flex-wrap items-center gap-3 pt-2">
                <button
                  type="submit"
                  id="wa-submit"
                  class="btn-whatsapp px-7 py-3 text-sm flex items-center gap-2 cursor-pointer"
                >
                  <svg
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-4 h-4 shrink-0"
                  >
                    <path
                      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
                    ></path>
                    <path
                      d="M12 0C5.373 0 0 5.373 0 12c0 2.136.564 4.14 1.548 5.875L.057 23.886a.5.5 0 00.612.612l6.011-1.491A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.882a9.87 9.87 0 01-5.022-1.373l-.36-.214-3.733.926.944-3.648-.234-.375A9.865 9.865 0 012.118 12C2.118 6.48 6.48 2.118 12 2.118S21.882 6.48 21.882 12 17.52 21.882 12 21.882z"
                    ></path>
                  </svg>
                  Send via WhatsApp
                </button>
                <a
                  href="tel:+917006087182"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-semibold text-sm border-2 transition-all"
                  style="border-color: var(--color-lab-green); color: var(--color-lab-green)"
                >
                  <PhoneCall className="w-4 h-4" />
                  Call Instead
                </a>
                <span
                  class="text-xs"
                  style="color: var(--color-muted-foreground)"
                  >Opens WhatsApp with your details pre-filled.</span
                >
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Placeholder -->
  <section
    class="section-padding border-t"
    style="background-color: var(--color-lab-light); border-color: var(--color-border)"
  >
    <div class="container-tight">
      <div class="text-center mb-10">
        <span class="section-tag">Location</span>
        <h2 class="section-title">Find Us</h2>
        <p class="section-subtitle mx-auto">
          Located in the heart of Pampore, easily accessible from Srinagar and
          surrounding areas.
        </p>
      </div>
      <div
        class="rounded-2xl overflow-hidden border h-80 flex items-center justify-center"
        style="border-color: var(--color-border); background: linear-gradient(135deg, rgba(13,107,58,0.07), rgba(22,163,74,0.12))"
      >
        <div class="text-center">
          <div class="text-6xl mb-4">🗺️</div>
          <p
            class="text-xl font-semibold"
            style="font-family: var(--font-heading); color: var(--color-lab-green)"
          >
            Main Chowk, Pampore
          </p>
          <p class="text-sm mt-1" style="color: var(--color-muted-foreground)">
            Jammu & Kashmir — 192121
          </p>
          <a
            href="https://maps.google.com/?q=Mir+Diagnostics+Pampore"
            target="_blank"
            rel="noopener"
            class="mt-4 inline-block text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors"
            style="background-color: var(--color-lab-green)"
          >
            Open in Google Maps →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const WA_NUMBER = "917006087182"; // ← update with real number
  const form = document.getElementById("appt-form") as HTMLFormElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const fname = data.get("fname") || "";
    const lname = data.get("lname") || "";
    const phone = data.get("phone") || "";
    const service = data.get("service") || "Not specified";
    const date = data.get("date") || "Not specified";
    const time = data.get("time") || "Not specified";
    const notes = data.get("notes") || "";

    const msg = [
      `Hello, I would like to book an appointment at *Mir Diagnostics, Pampore*.`,
      ``,
      `*Name:* ${fname} ${lname}`,
      `*Phone:* ${phone}`,
      `*Service:* ${service}`,
      `*Preferred Date:* ${date}`,
      `*Preferred Time:* ${time}`,
      notes ? `*Notes:* ${notes}` : "",
    ]
      .filter(Boolean)
      .join("\n");

    const url = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
    window.open(url, "_blank");
  });
</script>
