---
import Layout from "../layouts/Layout.astro";
import {
  Phone,
  Mail,
  MapPin,
  Clock,
  PhoneCall,
  MessageCircle,
  Map as MapIcon,
  AlertCircle,
  ArrowRight,
} from "lucide-react";

const WA = "917006087182";

const contactDetails = [
  {
    icon: MapPin,
    label: "Address",
    value: "Khrew Bus Stop, Namblabal, Pampore, J&K — 192121",
  },
  {
    icon: Phone,
    label: "Phone",
    value: "7006087182 / 9055998899",
  },
  {
    icon: Mail,
    label: "Email",
    value: "mirdiagnowtics256@gmail.com",
  },
  {
    icon: Clock,
    label: "Hours",
    value: "Mon–Sat: 7:00 AM – 8:00 PM\nSunday: 8:00 AM – 2:00 PM",
  },
];
---

<Layout
  title="Contact Us | Mir Diagnostics"
  description="Get in touch with Mir Diagnostics – book appointments, find our location, and reach our team in Pampore, Kashmir."
>
  <main id="main-content">
    <section
      class="pt-20 text-white"
      style="background: linear-gradient(135deg, var(--color-lab-green) 0%, #074d25 50%, var(--color-lab-teal) 100%)"
      aria-labelledby="contact-hero-title"
    >
      <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
        <span
          class="font-mono text-white/60 text-sm tracking-widest uppercase block mb-3"
          >— Get In Touch</span
        >
        <h1
          id="contact-hero-title"
          class="font-heading text-5xl md:text-6xl font-bold mb-4"
        >
          Contact Us
        </h1>
        <p class="text-white/80 text-xl max-w-2xl leading-relaxed">
          Book an appointment, ask a question, or find us on the map. We're here
          to help you prioritize your health.
        </p>
      </div>
    </section>

    <section class="section-padding bg-white" aria-labelledby="reach-us-title">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <div class="lg:col-span-1 space-y-6">
            <h2
              id="reach-us-title"
              class="font-heading text-2xl font-bold text-emerald-900 mb-6"
            >
              Reach Us
            </h2>

            <div class="space-y-4">
              {
                contactDetails.map((item) => {
                  const Icon = item.icon;
                  return (
                    <div class="flex items-start gap-4 p-5 bg-emerald-50/50 rounded-2xl border border-emerald-100 transition-colors hover:bg-emerald-50">
                      <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm">
                        <Icon
                          className="w-5 h-5 text-emerald-600"
                          strokeWidth={2.5}
                          aria-hidden="true"
                        />
                      </div>
                      <div>
                        <div class="text-[10px] font-mono text-emerald-600/70 uppercase tracking-widest mb-1 font-bold">
                          {item.label}
                        </div>
                        <address class="text-sm font-semibold text-emerald-950 not-italic whitespace-pre-line leading-relaxed">
                          {item.value}
                        </address>
                      </div>
                    </div>
                  );
                })
              }
            </div>

            <div
              class="bg-rose-50 border border-rose-100 rounded-2xl p-5 shadow-sm"
              role="alert"
            >
              <div class="flex items-center gap-2 mb-2 text-rose-700">
                <AlertCircle className="w-5 h-5 animate-pulse" />
                <span class="font-bold text-sm uppercase tracking-wide"
                  >Emergency Tests</span
                >
              </div>
              <p class="text-rose-900/70 text-sm leading-relaxed mb-3">
                For urgent sample processing or critical diagnostics, please
                contact our emergency coordination line:
              </p>
              <a
                href="tel:+917006087182"
                class="text-rose-700 font-black text-lg hover:underline transition-all"
              >
                +91 7006087182
              </a>
            </div>
          </div>

          <div
            class="lg:col-span-2 bg-white rounded-4xl border border-gray-100 p-8 shadow-xl shadow-emerald-900/5"
          >
            <h2 class="font-heading text-2xl font-bold text-emerald-950 mb-2">
              Book an Appointment
            </h2>
            <p class="text-gray-500 text-sm mb-8">
              Submit the form below. Our team will review your request and
              confirm your slot via WhatsApp or phone.
            </p>

            <form class="space-y-6" id="appt-form">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label
                    class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                    for="fname">First Name *</label
                  >
                  <input
                    id="fname"
                    name="fname"
                    type="text"
                    required
                    placeholder="e.g. Mohammad"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all"
                  />
                </div>
                <div>
                  <label
                    class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                    for="lname">Last Name *</label
                  >
                  <input
                    id="lname"
                    name="lname"
                    type="text"
                    required
                    placeholder="e.g. Mir"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label
                    class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                    for="phone">Phone Number *</label
                  >
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    required
                    placeholder="+91 70060 87182"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all"
                  />
                </div>
                <div>
                  <label
                    class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                    for="service">Service Required *</label
                  >
                  <select
                    id="service"
                    name="service"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all cursor-pointer"
                  >
                    <option value="">Select a service</option>
                    <option>Blood Test / Pathology</option>
                    <option>Ultrasound (USG)</option>
                    <option>Color Doppler</option>
                    <option>Obstetric Scan</option>
                    <option>Health Package</option>
                    <option>Home Sample Collection</option>
                    <option>Other</option>
                  </select>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label
                    class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                    for="date">Preferred Date *</label
                  >
                  <input
                    id="date"
                    name="date"
                    type="date"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all cursor-pointer"
                  />
                </div>
                <div>
                  <span
                    class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                    >Time Slot</span
                  >
                  <div class="flex flex-wrap gap-2">
                    {
                      ["7:00 AM", "11:00 AM", "3:00 PM", "5:00 PM"].map((t) => (
                        <label class="relative cursor-pointer group">
                          <input
                            type="radio"
                            name="time"
                            value={t}
                            class="peer sr-only"
                          />
                          <span class="px-3 py-1.5 rounded-lg border border-gray-200 text-xs font-bold text-gray-400 peer-checked:border-emerald-500 peer-checked:bg-emerald-500 peer-checked:text-white transition-all block">
                            {t}
                          </span>
                        </label>
                      ))
                    }
                  </div>
                </div>
              </div>

              <div>
                <label
                  class="block text-xs font-bold text-emerald-900 uppercase tracking-wider mb-2"
                  for="notes">Additional Notes</label
                >
                <textarea
                  id="notes"
                  name="notes"
                  rows={3}
                  placeholder="e.g. Home collection required, referral doctor name, etc."
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50/50 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all resize-none"
                ></textarea>
              </div>

              <div class="pt-4 flex flex-col sm:flex-row items-center gap-4">
                <button
                  type="submit"
                  class="btn-whatsapp w-full sm:w-auto px-10 py-4 shadow-lg shadow-emerald-100 flex items-center justify-center gap-2 group"
                >
                  <MessageCircle
                    className="w-5 h-5 group-hover:scale-110 transition-transform"
                  />
                  Request via WhatsApp
                </button>
                <a
                  href={`tel:+91${WA}`}
                  class="btn-outline w-full sm:w-auto px-10 py-3 rounded-full flex items-center justify-center gap-2"
                >
                  <PhoneCall className="w-4 h-4" />
                  Call Directly
                </a>
              </div>
              <p class="text-[10px] text-gray-400 italic">
                * Note: This form will open WhatsApp with your details
                pre-filled.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section
      class="section-padding bg-emerald-50/30 border-t border-emerald-100"
      aria-labelledby="map-title"
    >
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="text-center mb-12">
          <span class="section-tag" aria-hidden="true">Location</span>
          <h2 id="map-title" class="section-title">Find Our Centre</h2>
          <p class="section-subtitle mx-auto">
            Conveniently located at Main Chowk Pampore, accessible to everyone
            in the valley.
          </p>
        </div>

        <div
          class="rounded-[2.5rem] overflow-hidden border border-emerald-100 h-96 relative group shadow-2xl"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-emerald-100 to-emerald-50 flex items-center justify-center overflow-hidden"
          >
            <MapIcon
              className="w-64 h-64 text-emerald-200/50 absolute -rotate-12"
            />
            <div class="relative z-10 text-center p-8">
              <div
                class="w-16 h-16 bg-emerald-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-emerald-900/20"
              >
                <MapPin className="w-8 h-8 text-white animate-bounce" />
              </div>
              <h3
                class="text-2xl font-black text-emerald-900 mb-2"
                style="font-family: var(--font-heading)"
              >
                Main Chowk, Pampore
              </h3>
              <p class="text-emerald-700/70 mb-8 font-medium">
                Jammu & Kashmir — 192121 (Khrew Bus Stop)
              </p>
              <a
                href="https://maps.google.com/?q=Mir+Diagnostics+Pampore"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-emerald-900 text-white px-8 py-3 rounded-full font-bold hover:bg-emerald-800 transition-all shadow-lg"
              >
                Get Directions <ArrowRight className="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  const WA_NUMBER = "917006087182";
  const form = document.getElementById("appt-form");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const fname = data.get("fname") || "";
    const lname = data.get("lname") || "";
    const phone = data.get("phone") || "";
    const service = data.get("service") || "Not specified";
    const date = data.get("date") || "Not specified";
    const time = data.get("time") || "Not specified";
    const notes = data.get("notes") || "";

    const msg = [
      `Hello, I would like to book an appointment at *Mir Diagnostics, Pampore*.`,
      ``,
      `*Name:* ${fname} ${lname}`,
      `*Phone:* ${phone}`,
      `*Service:* ${service}`,
      `*Preferred Date:* ${date}`,
      `*Preferred Time:* ${time}`,
      notes ? `*Notes:* ${notes}` : "",
    ]
      .filter(Boolean)
      .join("\n");

    const url = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
    window.open(url, "_blank");
  });
</script>
