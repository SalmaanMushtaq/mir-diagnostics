---
import Layout from "../layouts/Layout.astro";
import {
  Phone,
  Check,
  Info,
  MessageCircle,
  PhoneCall,
  Activity,
  Microscope,
  ChevronDown,
  Sparkles,
} from "lucide-react";

const WA = "917006087182";

const packages = [
  {
    name: "Genetic 1.4 Package",
    params: 66,
    discount: 38,
    original: 4000,
    price: 2500,
    tests: [
      "Complete Blood Count",
      "Liver Function Test",
      "Kidney Function Test",
      "Thyroid Function Tests",
      "Lipid Profile",
      "Iron Deficiency Profile",
      "HbA1c",
      "Vit. D & Vit. B12",
      "HIV 1&2 Quantitative",
      "CRP Quantitative",
      "Anti-HCV",
      "RA Factor",
    ],
    highlight: true,
  },
  {
    name: "Genetic 1.3 Package",
    params: 62,
    discount: 40,
    original: 3000,
    price: 1800,
    tests: [
      "Complete Blood Count",
      "Liver Function Test",
      "Kidney Function Test",
      "Thyroid Function Tests",
      "Lipid Profile",
      "Iron Deficiency Profile",
      "HbA1c",
      "Vit. D & Vit. B12",
    ],
    highlight: false,
  },
  {
    name: "Genetic 1.2 Package",
    params: 60,
    discount: 33,
    original: 1800,
    price: 1200,
    tests: [
      "Complete Blood Count",
      "Liver Function Test",
      "Kidney Function Test",
      "Thyroid Function Tests",
      "Lipid Profile",
      "Iron Deficiency Profile",
      "HbA1c",
    ],
    highlight: false,
  },
  {
    name: "Genetic 1.1 Package",
    params: 59,
    discount: 33,
    original: 1200,
    price: 800,
    tests: [
      "Complete Blood Count",
      "Liver Function Test",
      "Kidney Function Test",
      "Thyroid Function Tests",
      "Lipid Profile",
      "Iron Deficiency Profile",
    ],
    highlight: false,
  },
];
---

<Layout
  title="Services – USG & Health Packages | Mir Diagnostics"
  description="Mir Diagnostics Services: Advanced USG imaging and comprehensive health packages in Pampore, Kashmir."
>
  <main id="main-content">
    <section
      class="pt-20 text-white"
      style="background: linear-gradient(135deg, var(--color-lab-green) 0%, #074d25 50%, var(--color-lab-teal) 100%)"
      aria-labelledby="services-hero-title"
    >
      <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
        <span
          class="text-sm tracking-widest uppercase mb-3 block opacity-70"
          style="font-family: var(--font-mono);"
        >
          — Diagnostics & Imaging
        </span>
        <h1
          id="services-hero-title"
          class="text-5xl md:text-6xl font-bold mt-1 mb-4"
          style="font-family: var(--font-heading)"
        >
          Clinical Services
        </h1>
        <p class="text-xl max-w-2xl text-white/80 leading-relaxed">
          Advanced USG imaging, comprehensive health packages, and full-spectrum
          laboratory testing — all under one roof in Pampore.
        </p>
        <nav
          class="flex flex-wrap gap-3 mt-8"
          aria-label="Services quick links"
        >
          <a
            href="#usg"
            class="px-6 py-3 rounded-full text-sm font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-all flex items-center gap-2 focus:ring-2 focus:ring-white"
          >
            <ChevronDown className="w-4 h-4" /> USG Services
          </a>
          <a
            href="#packages"
            class="px-6 py-3 rounded-full text-sm font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-all flex items-center gap-2 focus:ring-2 focus:ring-white"
          >
            <ChevronDown className="w-4 h-4" /> Health Packages
          </a>
        </nav>
      </div>
    </section>

    <section
      id="usg"
      class="section-padding scroll-mt-20"
      aria-labelledby="usg-main-title"
    >
      <div class="container-tight">
        <div class="text-center mb-14">
          <span class="section-tag" aria-hidden="true">Radiology & Imaging</span
          >
          <h2 id="usg-main-title" class="section-title">
            Ultrasound (USG) Services
          </h2>
          <p class="section-subtitle mx-auto">
            High-definition ultrasound imaging performed by experienced
            radiologists — safe, fast, and non-invasive.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
          <article>
            <p class="leading-relaxed mb-4 text-gray-600">
              Ultrasonography (USG) uses high-frequency sound waves to create
              real-time images of internal organs. Unlike X-rays, it uses no
              ionizing radiation — making it safe even during pregnancy.
            </p>
            <p class="leading-relaxed mb-8 text-gray-600">
              Our USG department uses latest-generation machines including color
              Doppler and 4D imaging. All scans are supervised by qualified
              radiologists with same-day reports.
            </p>
            <a
              href={`https://wa.me/${WA}?text=Hello%2C%20I%20want%20to%20book%20a%20USG%20scan.`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-whatsapp inline-flex items-center gap-2"
              aria-label="Book USG appointment on WhatsApp"
            >
              <MessageCircle className="w-5 h-5" /> Book USG on WhatsApp
            </a>
          </article>

          <aside
            class="rounded-2xl p-8 border border-emerald-100 bg-emerald-50/30"
            aria-labelledby="usg-benefits-title"
          >
            <h3
              id="usg-benefits-title"
              class="text-xl font-bold mb-6 text-emerald-900"
              style="font-family: var(--font-heading);"
            >
              Why USG at Mir Diagnostics?
            </h3>
            <ul class="space-y-4">
              {
                [
                  "No radiation — completely safe",
                  "Real-time organ visualization",
                  "Same-day reports",
                  "Safe for pregnancy & children",
                  "Guides biopsies and procedures",
                  "Color Doppler & 4D capability",
                ].map((benefit) => (
                  <li class="flex items-center gap-3 text-sm font-medium text-emerald-800">
                    <Check
                      className="w-5 h-5 text-emerald-600 shrink-0"
                      aria-hidden="true"
                    />
                    {benefit}
                  </li>
                ))
              }
            </ul>
          </aside>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            [
              {
                title: "Abdominal USG",
                badge: "Common",
                prep: "Fast 4–6 hrs",
                desc: "Liver, gallbladder, spleen, pancreas, kidneys. Detects gallstones, fatty liver, cysts, tumors.",
              },
              {
                title: "Pelvic USG",
                badge: "Gynecology",
                prep: "Full bladder",
                desc: "Uterus, ovaries, pelvic structures. Identifies fibroids, ovarian cysts, and pelvic pathology.",
              },
              {
                title: "Obstetric USG",
                badge: "Pregnancy",
                prep: "Doctor's advice",
                desc: "Fetal growth, placenta, amniotic fluid monitoring. NT scan, anomaly scan, growth scans.",
              },
              {
                title: "Color Doppler",
                badge: "Vascular",
                prep: "No prep needed",
                desc: "Blood flow in arteries and veins. Detects DVT, carotid stenosis, renal artery stenosis.",
              },
              {
                title: "Thyroid USG",
                badge: "Endocrine",
                prep: "No prep needed",
                desc: "Thyroid nodules, goiter, thyroiditis. Guides FNAC biopsies.",
              },
              {
                title: "Musculoskeletal USG",
                badge: "Orthopedic",
                prep: "No prep needed",
                desc: "Muscles, tendons, ligaments. Evaluates injuries, effusions, and soft tissue masses.",
              },
              {
                title: "Breast USG",
                badge: "Women's",
                prep: "No prep needed",
                desc: "Breast lumps and cysts. Complementary to mammography for dense breast tissue.",
              },
              {
                title: "Scrotal USG",
                badge: "Urology",
                prep: "No prep needed",
                desc: "Testes, epididymis. Detects varicocele, hydrocele, and torsion.",
              },
            ].map((s) => {
              const waMsg = encodeURIComponent(
                `Hello, I want to book a *${s.title}* at Mir Diagnostics.`,
              );
              return (
                <section
                  class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm transition-all hover:shadow-md"
                  aria-labelledby={`usg-type-${s.title.toLowerCase().replace(/\s/g, "-")}`}
                >
                  <div class="flex items-start justify-between mb-3">
                    <h3
                      id={`usg-type-${s.title.toLowerCase().replace(/\s/g, "-")}`}
                      class="font-bold text-lg text-emerald-900"
                      style="font-family: var(--font-heading);"
                    >
                      {s.title}
                    </h3>
                    <span class="text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full bg-emerald-100 text-emerald-700">
                      {s.badge}
                    </span>
                  </div>
                  <p class="text-sm text-gray-600 leading-relaxed mb-6">
                    {s.desc}
                  </p>
                  <div class="flex items-center justify-between pt-4 border-t border-gray-50">
                    <span class="text-xs font-bold text-amber-600 flex items-center gap-1.5">
                      <Info className="w-4 h-4" aria-hidden="true" />
                      PREP: {s.prep}
                    </span>
                    <a
                      href={`https://wa.me/${WA}?text=${waMsg}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-bold text-emerald-600 flex items-center gap-1 hover:text-emerald-700 transition-colors"
                    >
                      Book Scan <ChevronDown className="w-3 h-3 -rotate-90" />
                    </a>
                  </div>
                </section>
              );
            })
          }
        </div>
      </div>
    </section>

    <div
      class="h-1 bg-linear-to-r from-emerald-800 to-emerald-500"
      role="presentation"
      aria-hidden="true"
    >
    </div>

    <section
      id="packages"
      class="section-padding scroll-mt-20"
      style="background: #f8fafc"
      aria-labelledby="packages-section-title"
    >
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-12">
          <span class="section-tag" aria-hidden="true">Value Panels</span>
          <h2 id="packages-section-title" class="section-title">
            Genetic Health Packages
          </h2>
          <p class="section-subtitle mx-auto">
            Precision testing with bundled savings.
          </p>
        </div>

        <div class="flex flex-col gap-6">
          {
            packages.map((pkg) => {
              const waMsg = encodeURIComponent(
                `Hello, I want to book the *${pkg.name}* (₹${pkg.price}).`,
              );
              return (
                <section
                  class={`group relative bg-white rounded-3xl overflow-hidden border transition-all duration-300 hover:shadow-xl hover:border-emerald-200 ${
                    pkg.highlight
                      ? "ring-2 ring-emerald-500 border-transparent shadow-lg"
                      : "border-gray-300 "
                  }`}
                  aria-labelledby={`pkg-name-${pkg.name.toLowerCase().replace(/\s/g, "-")}`}
                >
                  {/* Desktop View: Horizontal Flex | Mobile View: Vertical Stack */}
                  <div class="flex flex-col md:flex-row">
                    <div class="p-8 md:w-1/3 bg-emerald-50/30 border-b md:border-b-0 md:border-r border-emerald-50">
                      {pkg.highlight && (
                        <span class="inline-flex items-center gap-1 text-[10px] font-black text-amber-600 bg-amber-100 px-2 py-0.5 rounded-full mb-3">
                          <Sparkles className="w-3 h-3" /> BEST VALUE
                        </span>
                      )}
                      <h3
                        id={`pkg-name-${pkg.name.toLowerCase().replace(/\s/g, "-")}`}
                        class="text-2xl font-black text-emerald-950 mb-2"
                        style="font-family: var(--font-heading);"
                      >
                        {pkg.name}
                      </h3>
                      <div class="flex items-center gap-2 text-emerald-700 font-bold text-sm">
                        <Activity className="w-4 h-4" />
                        {pkg.params} Parameters included
                      </div>
                      <div class="mt-4 text-emerald-600/60 text-xs font-medium uppercase tracking-tighter">
                        Full Body Screening Panel
                      </div>
                    </div>

                    <div class="p-8 flex-1">
                      <h4 class="sr-only">Included Tests</h4>
                      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
                        {pkg.tests.map((t) => (
                          <li class="flex items-center gap-2 text-[13px] text-gray-600 group-hover:text-emerald-900 transition-colors">
                            <Check
                              className="w-4 h-4 text-emerald-500 shrink-0"
                              strokeWidth={3}
                            />
                            {t}
                          </li>
                        ))}
                      </ul>
                    </div>

                    <div class="p-8 md:w-64 bg-emerald-900 text-white flex flex-col justify-center items-center text-center">
                      <div class="mb-4">
                        <del class="block text-emerald-400/60 text-sm font-bold">
                          ₹{pkg.original.toLocaleString()}
                        </del>
                        <div
                          class="text-4xl font-black"
                          style="font-family: var(--font-heading);"
                        >
                          ₹{pkg.price.toLocaleString()}
                        </div>
                        <span class="text-[10px] uppercase tracking-widest font-bold text-emerald-400">
                          -{pkg.discount}% OFF
                        </span>
                      </div>

                      <a
                        href={`https://wa.me/${WA}?text=${waMsg}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full bg-white text-emerald-900 font-bold py-3 rounded-2xl hover:bg-emerald-50 transition-colors flex items-center justify-center gap-2"
                      >
                        <MessageCircle className="w-4 h-4" />
                        Book Now
                      </a>
                    </div>
                  </div>
                </section>
              );
            })
          }
        </div>
      </div>
    </section>

    <section
      class="container-tight my-16 rounded-3xl p-10 text-white text-center shadow-2xl bg-linear-to-br from-emerald-800 to-emerald-600"
      aria-labelledby="custom-pkg-title"
    >
      <h3
        id="custom-pkg-title"
        class="text-3xl font-bold mb-4"
        style="font-family: var(--font-heading);"
      >
        Need a Custom Package?
      </h3>
      <p class="mb-8 text-emerald-100 text-lg max-w-2xl mx-auto">
        Talk to our diagnostic experts and we'll create a personalised health
        panel tailored to your specific clinical needs.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`https://wa.me/${WA}?text=Custom%20Package%20Inquiry`}
          class="btn-whatsapp px-10 py-4 text-base shadow-lg"
        >
          <MessageCircle className="w-5 h-5" /> WhatsApp Us
        </a>
        <a
          href="tel:+917006087182"
          class="border-2 border-white/30 hover:bg-white/10 px-10 py-4 rounded-full font-bold transition-all flex items-center gap-2 focus:ring-2 focus:ring-white"
        >
          <PhoneCall className="w-5 h-5 text-emerald-400" /> Call Now
        </a>
      </div>
    </section>
  </main>
</Layout>
