    price: 600,
    tests: [
      "Thyroid Profile",
      "CBC",
      "Lipid Profile",
      "KFT",
      "LFT",
      "Calcium",
      "Electrolytes",
      "HbA1c",
    ],
    highlight: false,
    img: "/pkg-profile11-600.jpg",
  },
  {
    name: "Body Profile 1.2",
    params: 10,
    discount: 50,
    original: 2000,
    price: 999,
    tests: [
      "Thyroid Profile",
      "CBC",
      "Lipid Profile",
      "KFT",
      "LFT",
      "Calcium",
      "Electrolytes",
      "HbA1c",
      "Iron Profile",
      "Vitamin D",
    ],
    highlight: false,
    img: "/pkg-profile12-999.jpg",
  },
  {
    name: "Body Profile 1.3",
    params: 11,
    discount: 50,
    original: 3000,
    price: 1499,
    tests: [
      "Thyroid Profile",
      "CBC",
      "Lipid Profile",
      "KFT",
      "LFT",
      "Calcium",
      "Electrolytes",
      "HbA1c",
      "Vitamin D",
      "Vitamin B12",
      "Testosterone",
    ],
    highlight: true,
    img: "/pkg-profile12-1499.jpg",
  },
  {
    name: "Body Profile 3",
    params: 11,
    discount: 57,
    original: 3500,
    price: 1499,
    tests: [
      "Vitamin D3",
      "Vitamin B12",
      "Testosterone",
      "Thyroid Profile",
      "HbA1c",
      "Iron Profile",
      "CBC",
      "ESR",
      "Lipid Profile",
      "LFT",
      "Electrolytes",
    ],
    highlight: false,
    img: "/body-profile-3.jpg",
  },
];

const additionalServices = [
  {
    id: "fibroscan",
    name: "FibroScan",
    subtitle: "Liver Stiffness Assessment",
    badge: "Non-Invasive",
    badgeColor: "bg-violet-600",
    description:
      "FibroScan is a painless, non-invasive ultrasound-based test that measures liver stiffness and fatty change (CAP score). It is the gold standard for assessing liver fibrosis without a biopsy.",
    features: [
      "Liver fibrosis staging (F0–F4)",
      "Fatty liver (steatosis) grading",
      "Results in under 10 minutes",
      "No needles, no pain, no radiation",
      "Ideal for Hepatitis B/C, NAFLD, cirrhosis monitoring",
    ],
    prep: "2-hour fast required. Avoid heavy exercise before the test.",
    img: "/fibroscan.jpg",
    waText: "Hello, I want to book a *FibroScan* at Mir Diagnostics, Pampore.",
  },
  {
    id: "echo",
    name: "Echocardiogram",
    subtitle: "Cardiac Ultrasound (Echo)",
    badge: "Cardiology",
    badgeColor: "bg-red-600",
    description:
      "An echocardiogram uses ultrasound to produce real-time images of the heart — its chambers, valves, and pumping function. Essential for diagnosing heart failure, valve disease, and cardiomyopathy.",
    features: [
      "2D & Doppler Echo",
      "Assessment of heart function (EF)",
      "Valve disease evaluation",
      "Pericardial effusion detection",
      "Congenital heart defect screening",
    ],
    prep: "No special preparation needed. Wear comfortable clothing.",
    img: "/echocardiogram.jpg",
    waText:
      "Hello, I want to book an *Echocardiogram (Echo)* at Mir Diagnostics, Pampore.",
  },
  {
    id: "ecg",
    name: "ECG / EKG",
    subtitle: "Electrocardiogram",
    badge: "Cardiac",
    badgeColor: "bg-orange-600",
    description:
      "An ECG records the electrical activity of your heart. It is the first-line test for detecting arrhythmias, heart attacks, conduction defects, and is mandatory before surgeries.",
    features: [
      "12-lead ECG",
      "Arrhythmia detection",
      "Myocardial infarction (MI) screening",
      "Pre-operative cardiac clearance",
      "Instant results — under 5 minutes",
    ],
    prep: "No preparation needed. Avoid oily skin creams before test.",
    img: "/electrocardiogram.jpg",
    waText: "Hello, I want to book an *ECG* at Mir Diagnostics, Pampore.",
  },
  {
    id: "xray",
    name: "X-Ray",
    subtitle: "Digital Radiography",
    badge: "Radiology",
    badgeColor: "bg-sky-700",
    description:
      "Our digital X-ray facility provides high-resolution radiographic imaging for chest, bones, abdomen and more. Digital technology means lower radiation exposure, faster results, and better image quality.",
    features: [
      "Chest X-Ray (PA & Lateral)",
      "Bone & Joint X-Rays",
      "Abdominal X-Ray",
      "Spine & Lumbar X-Ray",
      "Dental X-Ray",
      "Low radiation digital system",
    ],
    prep: "Remove metal jewellery. Specific prep varies by body part.",
    img: "/x-ray.jpg",
    waText: "Hello, I want to book an *X-Ray* at Mir Diagnostics, Pampore.",
  },
  {
    id: "pharmacy",
    name: "Pharmacy",
    subtitle: "In-House Medical Store",
    badge: "On-Site",
    badgeColor: "bg-emerald-700",
    description:
      "Our in-house pharmacy stocks a wide range of prescription medicines, OTC drugs, supplements, and diagnostic consumables. Get your prescribed medications immediately after your consultation or test.",
    features: [
      "Prescription & OTC medicines",
      "Vitamins & supplements",
      "Diabetic & cardiac drugs",
      "Vaccines & injectables",
      "Open during lab hours",
    ],
    prep: "Bring your prescription. We also dispense against lab reports.",
    img: "/pharmacy.jpg",
    waText:
      "Hello, I have a query about the *Pharmacy* at Mir Diagnostics, Pampore.",
  },
];
---

<Layout
  title="Services – USG, FibroScan, ECG, X-Ray & Packages"
  description="Mir Diagnostics Pampore: USG, FibroScan, Echocardiogram, ECG, X-Ray, Pharmacy and Health Packages with WhatsApp booking."
>
  <section
    class="pt-20 text-white bg-linear-to-br from-[#0D6B3A] via-[#074d25] to-[#16A34A]"
  >
    <div class="max-w-7xl mx-auto section-padding py-20">
      <span
        class="text-sm tracking-widest uppercase mb-3 block opacity-60 font-mono"
        >— Diagnostics & Imaging</span
      >
      <h1 class="text-5xl md:text-6xl font-bold mt-1 mb-4 font-heading">
        Clinical Services
      </h1>
      <p class="text-xl max-w-2xl leading-relaxed text-white/80">
        Advanced USG imaging · FibroScan · Echo · ECG · X-Ray · In-house
        Pharmacy · Health Packages — all at Mir Diagnostics, Pampore.
      </p>
      <div class="flex flex-wrap gap-2 mt-8">
        {
          [
            "#usg",
            "#fibroscan",
            "#echo",
            "#ecg",
            "#xray",
            "#pharmacy",
            "#packages",
          ].map((href) => {
            const labels = {
              "#usg": "USG",
              "#fibroscan": "FibroScan",
              "#echo": "Echo",
              "#ecg": "ECG",
              "#xray": "X-Ray",
              "#pharmacy": "Pharmacy",
              "#packages": "Packages",
            };
            return (
              <a
                href={href}
                class="px-4 py-2 rounded-full text-xs font-bold border-2 border-white/25 text-white hover:bg-white/15 transition-all"
              >
                {labels[href as keyof typeof labels]}
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <section id="usg" class="section-padding scroll-mt-20 bg-white">
    <div class="container-tight">
      <div class="text-center mb-14">
        <span class="section-tag">Radiology & Imaging</span>
        <h2 class="section-title">Ultrasound (USG) Services</h2>
        <p class="section-subtitle mx-auto text-slate-500">
          High-definition ultrasound by experienced radiologists — safe, fast,
          non-invasive.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-14">
        <div>
          <p class="leading-relaxed mb-4 text-slate-600">
            Ultrasonography (USG) uses high-frequency sound waves to create
            real-time images of internal organs. No ionizing radiation — safe
            even during pregnancy.
          </p>
          <p class="leading-relaxed mb-6 text-slate-600">
            Our USG department features latest-generation machines with color
            Doppler and 4D imaging. All scans supervised by qualified
            radiologists. Same-day reports.
          </p>
          <a
            href={`https://wa.me/${WA}?text=Hello%2C%20I%20want%20to%20book%20a%20USG%20scan%20at%20Mir%20Diagnostics%2C%20Pampore.`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-whatsapp"
          >
            <WhatsAppIcon />
            Book USG on WhatsApp
          </a>
        </div>
        <div class="rounded-md md:rounded-xl overflow-hidden shadow-md">
          <img
            src="/usg-facilities.jpg"
            alt="USG facilities at Mir Diagnostics Pampore"
            class="w-full object-cover max-h-90"
            loading="lazy"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {
          [
            {
              title: "Abdominal USG",
              badge: "Common",
              prep: "Fast 4–6 hrs",
              desc: "Liver, gallbladder, spleen, pancreas, kidneys. Detects gallstones, fatty liver, cysts, tumors.",
            },
            {
              title: "Pelvic USG",
              badge: "Gynecology",
              prep: "Full bladder",
              desc: "Uterus, ovaries, pelvic structures. Identifies fibroids, ovarian cysts, and pelvic pathology.",
            },
            {
              title: "Obstetric USG",
              badge: "Pregnancy",
              prep: "Doctor's advice",
              desc: "Fetal growth, placenta, amniotic fluid. NT scan, anomaly scan, dating scan.",
            },
            {
              title: "Color Doppler",
              badge: "Vascular",
              prep: "No prep needed",
              desc: "Blood flow in arteries and veins. Detects DVT, carotid stenosis, renal artery stenosis.",
            },
            {
              title: "3D/4D Ultrasound",
              badge: "Advanced",
              prep: "Doctor's advice",
              desc: "Detailed three and four-dimensional imaging for obstetric and anatomical evaluation.",
            },
            {
              title: "NT / NB Scan",
              badge: "Pregnancy",
              prep: "Doctor's advice",
              desc: "Nuchal translucency scan for Down syndrome risk assessment at 11–14 weeks.",
            },
            {
              title: "Level-II Scan",
              badge: "Fetal",
              prep: "Doctor's advice",
              desc: "Detailed fetal anomaly scan at 18–22 weeks. Evaluates all organ systems.",
            },
            {
              title: "Thyroid USG",
              badge: "Endocrine",
              prep: "No prep needed",
              desc: "Thyroid nodules, goiter, thyroiditis. Guides FNAC biopsies.",
            },
            {
              title: "Breast USG",
              badge: "Women's",
              prep: "No prep needed",
              desc: "Breast lumps and cysts. Complementary to mammography for dense breast tissue.",
            },
            {
              title: "Musculoskeletal USG",
              badge: "Orthopedic",
              prep: "No prep needed",
              desc: "Muscles, tendons, ligaments. Evaluates injuries, effusions, and soft tissue masses.",
            },
            {
              title: "Scrotal USG",
              badge: "Urology",
              prep: "No prep needed",
              desc: "Testes, epididymis. Detects varicocele, hydrocele, and torsion.",
            },
            {
              title: "USG Neck",
              badge: "Neck",
              prep: "No prep needed",
              desc: "Neck masses, lymph nodes, salivary glands, and soft tissue evaluation.",
            },
            {
              title: "USG Chest",
              badge: "Thoracic",
              prep: "No prep needed",
              desc: "Pleural effusion, chest wall masses, and guided thoracentesis.",
            },
            {
              title: "Dating & Cardiac Scan",
              badge: "Pregnancy",
              prep: "Doctor's advice",
              desc: "Early pregnancy dating and fetal cardiac assessment.",
            },
          ].map((s) => {
            const waMsg = encodeURIComponent(
              `Hello, I want to book a *${s.title}* at Mir Diagnostics, Pampore.`,
            );
            const badgeColors = {
              Common: "bg-green-600",
              Gynecology: "bg-pink-600",
              Pregnancy: "bg-purple-600",
              Vascular: "bg-blue-600",
              Advanced: "bg-violet-600",
              Fetal: "bg-orange-600",
              Endocrine: "bg-cyan-600",
              "Women's": "bg-rose-500",
              Orthopedic: "bg-amber-600",
              Urology: "bg-sky-700",
              Neck: "bg-emerald-600",
              Thoracic: "bg-indigo-600",
              "Dating & Cardiac Scan": "bg-red-700",
            };
            const bc =
              badgeColors[s.badge as keyof typeof badgeColors] ??
              "bg-green-600";
            return (
              <div class="bg-white rounded-md md:rounded-xl p-5 border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between mb-2">
                  <h3 class="font-bold text-base font-heading text-blue-900">
                    {s.title}
                  </h3>
                  <span
                    class={`text-[10px] font-black uppercase tracking-wider px-2.5 py-1 rounded-full shrink-0 ml-3 text-white ${bc}`}
                  >
                    {s.badge}
                  </span>
                </div>
                <p class="text-sm leading-relaxed mb-4 text-slate-500">
                  {s.desc}
                </p>
                <div class="flex items-center justify-between pt-3 border-t border-slate-100">
                  <span class="text-xs font-bold flex items-center gap-1 text-amber-600">
                    <Info className="w-3.5 h-3.5 shrink-0" /> {s.prep}
                  </span>
                  <a
                    href={`https://wa.me/${WA}?text=${waMsg}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-whatsapp py-1.5 px-3 text-xs rounded-md"
                  >
                    <WhatsAppIcon className="w-3.5 h-3.5 shrink-0" />
                    Book Now
                  </a>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  {
    additionalServices.map((svc, idx) => {
      const waMsg = encodeURIComponent(svc.waText);
      const isEven = idx % 2 === 0;
      return (
        <section
          id={svc.id}
          class={`section-padding scroll-mt-20 ${isEven ? "bg-slate-50" : "bg-white"}`}
        >
          <div class="container-tight">
            <div
              class={`grid grid-cols-1 lg:grid-cols-2 gap-14 items-center ${!isEven ? "lg:flex-row-reverse" : ""}`}
            >
              <div
                class={`rounded-md md:rounded-xl overflow-hidden shadow-md ${!isEven ? "lg:order-2" : ""}`}
              >
                <img
                  src={svc.img}
                  alt={`${svc.name} at Mir Diagnostics Pampore`}
                  class="w-full object-cover h-105"
                  loading="lazy"
                />
              </div>

              <div class={!isEven ? "lg:order-1" : ""}>
                <span
                  class={`inline-block text-white text-[10px] font-black px-3 py-1.5 rounded-full mb-4 uppercase tracking-widest ${svc.badgeColor}`}
                >
                  {svc.badge}
                </span>

                <h2 class="section-title mb-1">{svc.name}</h2>
                <p class="text-lg font-semibold mb-4 text-emerald-700">
                  {svc.subtitle}
                </p>

                <p class="leading-relaxed mb-5 text-base text-slate-600">
                  {svc.description}
                </p>

                <ul class="space-y-2.5 mb-6">
                  {svc.features.map((f) => (
                    <li class="flex items-start gap-3 text-sm font-medium text-slate-800">
                      <CheckCircle2 className="w-5 h-5 shrink-0 text-emerald-600" />
                      {f}
                    </li>
                  ))}
                </ul>

                <div class="flex items-start gap-3 rounded-xl p-4 mb-6 bg-amber-50 border border-amber-200/50">
                  <span class="shrink-0">
                    <Info className="w-5 h-5 text-amber-600" />
                  </span>
                  <div>
                    <p class="text-[10px] font-black uppercase tracking-wider mb-0.5 text-amber-600">
                      Preparation
                    </p>
                    <p class="text-sm text-slate-700">{svc.prep}</p>
                  </div>
                </div>

                <div class="flex flex-wrap gap-3">
                  <a
                    href={`https://wa.me/${WA}?text=${waMsg}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-whatsapp"
                  >
                    <WhatsAppIcon className="w-3.5 h-3.5 shrink-0" />
                    Book on WhatsApp
                  </a>
                  <a
                    href="tel:+917006087182"
                    class="btn-outline flex items-center gap-2 border-slate-200 text-slate-700 hover:bg-slate-50"
                  >
                    <PhoneCall className="w-3.5 h-3.5 shrink-0 text-amber-600" />{" "}
                    7006087182
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>
      );
    })
  }

  <section
    class="section-padding scroll-mt-20 bg-linear-to-br from-green-50 to-emerald-100"
  >
    <div class="container-tight">
      <div class="text-center mb-14">
        <span class="section-tag">Our Medical Team</span>
        <h2 class="section-title">Experienced Doctors</h2>
        <p class="section-subtitle mx-auto text-slate-600">
          Board-certified specialists bringing decades of expertise to every
          diagnosis at Mir Diagnostics, Pampore.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div
          class="bg-white rounded-md md:rounded-xl overflow-hidden shadow-md border border-slate-100 transition-transform hover:-translate-y-1"
        >
          <div class="relative">
            <img
              src="/dr-javid-magray.jpg"
              alt="Dr. Javid Magray"
              class="w-full object-cover object-top h-80"
              loading="lazy"
            />
            <div
              class="absolute bottom-0 left-0 right-0 px-6 py-4 text-white bg-linear-to-t from-emerald-900/95 to-transparent"
            >
              <p class="font-black text-xl font-heading">Dr. Javid Magray</p>
              <p class="text-sm font-medium opacity-90">Senior Radiologist</p>
            </div>
            <div
              class="absolute top-4 right-4 bg-white text-[10px] font-black px-3 py-1.5 rounded-full shadow-sm text-blue-900 uppercase tracking-wider"
            >
              ⭐ Featured
            </div>
          </div>
          <div class="p-6">
            <div class="flex flex-wrap gap-2 mb-4">
              {
                [
                  "USG & Doppler",
                  "3D/4D Imaging",
                  "Obstetric Scan",
                  "Echo",
                  "FibroScan",
                ].map((s) => (
                  <span class="text-[10px] font-bold uppercase px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-100">
                    {s}
                  </span>
                ))
              }
            </div>
            <blockquote
              class="italic text-base mb-4 pl-3 border-l-4 border-emerald-500 font-heading text-blue-900"
            >
              "Precision in every image, care in every diagnosis."
            </blockquote>
            <div
              class="flex items-center gap-3 p-3 rounded-md mb-4 bg-green-50"
            >
              <CalendarDays className="w-5 h-5 shrink-0 text-amber-600" />
              <div>
                <p class="font-bold text-sm text-green-950">
                  Available Everyday
                </p>
                <p class="text-[11px] text-green-800">
                  All kinds of ultrasounds · Pampore
                </p>
              </div>
            </div>
            <div class="flex gap-3">
              <a
                href={`https://wa.me/${WA}?text=Hello`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-whatsapp flex-1 justify-center"
              >
                <WhatsAppIcon className="w-3.5 h-3.5 shrink-0" />
                Book Appointment
              </a>
              <a
                href="tel:+917006087182"
                class="btn-outline px-4 border-slate-100 hover:bg-slate-50"
                ><PhoneCall className="w-5 h-5 text-amber-600" /></a
              >
            </div>
          </div>
        </div>

        <div
          class="bg-white rounded-md md:rounded-xl overflow-hidden shadow-md border border-slate-100 transition-transform hover:-translate-y-1"
        >
          <div class="relative">
            <img
              src="/lab-reception.jpg"
              alt="Lab Team"
              class="w-full object-cover h-80"
              loading="lazy"
            />
            <div
              class="absolute bottom-0 left-0 right-0 px-6 py-4 text-white bg-linear-to-t from-emerald-900/95 to-transparent"
            >
              <p class="font-black text-xl font-heading">Lab Pathologists</p>
              <p class="text-sm font-medium opacity-90">
                Qualified diagnostic team · Mon–Sat
              </p>
            </div>
          </div>
          <div class="p-6">
            <div class="flex flex-wrap gap-2 mb-4">
              {
                [
                  "Haematology",
                  "Biochemistry",
                  "Microbiology",
                  "Serology",
                  "Molecular PCR",
                ].map((s) => (
                  <span class="text-[10px] font-bold uppercase px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-100">
                    {s}
                  </span>
                ))
              }
            </div>
            <p class="text-sm leading-relaxed mb-5 text-slate-500">
              Our in-house pathologists and laboratory scientists oversee 500+
              tests daily. Every result is verified before release.
            </p>
            <div class="grid grid-cols-3 gap-3 mb-5">
              {
                [
                  { n: "500+", l: "Tests" },
                  { n: "Same Day", l: "Reports" },
                  { n: "NABL", l: "Standards" },
                ].map((s) => (
                  <div class="text-center p-3 rounded-xl bg-slate-50">
                    <div class="font-black text-sm text-blue-900">{s.n}</div>
                    <div class="text-[10px] uppercase tracking-tight text-slate-400">
                      {s.l}
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="flex gap-3">
              <a
                href={`https://wa.me/${WA}?text=Hello`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-whatsapp flex-1 justify-center"
              >
                <WhatsAppIcon className="w-3.5 h-3.5 shrink-0" /> Enquire on WhatsApp
              </a>
              <a
                href="tel:+919055998899"
                class="btn-outline px-4 border-slate-100 hover:bg-slate-50"
                ><PhoneCall className="w-5 h-5 text-amber-600" /></a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="packages" class="section-padding scroll-mt-20 bg-slate-50">
    <div class="container-tight">
      <div class="text-center mb-12">
        <span class="section-tag">Special Offers</span>
        <h2 class="section-title">Health Packages</h2>
        <p class="section-subtitle mx-auto text-slate-500">
          Comprehensive wellness panels with real savings — book instantly via
          WhatsApp.
        </p>
      </div>

      <div class="flex flex-col gap-6">
        {
          packages.map((pkg) => {
            const waMsg = encodeURIComponent(
              `Hello, I want to book *${pkg.name}* (₹${pkg.price})`,
            );
            return (
              <div
                class={`relative bg-white rounded-md md:rounded-xl overflow-hidden border transition-all duration-300 hover:shadow-xl ${pkg.highlight ? "border-emerald-500 shadow-emerald-900/10 shadow-lg" : "border-slate-200"}`}
              >
                {pkg.highlight && (
                  <div class="absolute top-4 right-4 z-10 text-white text-[10px] font-black px-3 py-1.5 rounded-full bg-amber-500 uppercase tracking-widest">
                    ⭐ Most Popular
                  </div>
                )}

                <div class="flex flex-col md:flex-row">
                  <div class="md:w-64 shrink-0 overflow-hidden min-h-45">
                    <img
                      src={pkg.img}
                      alt={pkg.name}
                      class="w-full h-full object-cover object-top"
                      loading="lazy"
                    />
                  </div>

                  <div class="p-6 flex-1">
                    <div class="flex items-center gap-3 mb-3">
                      <h3 class="text-2xl font-black font-heading text-blue-900">
                        {pkg.name}
                      </h3>
                      <span class="text-[10px] font-black uppercase px-2.5 py-1 rounded-full text-white bg-emerald-600 tracking-wider shrink-0">
                        {pkg.params} Tests
                      </span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
                      {pkg.tests.map((t) => (
                        <div class="flex items-center gap-2 text-sm text-slate-700">
                          <CheckCircle2 className="w-4 h-4 shrink-0 text-emerald-600" />
                          {t}
                        </div>
                      ))}
                    </div>
                  </div>

                  <div class="p-6 md:w-56 flex flex-col justify-center items-center text-center shrink-0 bg-[#0b2618]">
                    <div class="text-sm line-through mb-1 text-white/60">
                      ₹{pkg.original.toLocaleString()}
                    </div>
                    <div class="text-4xl font-black text-white mb-1 font-heading">
                      ₹{pkg.price.toLocaleString()}
                    </div>
                    <div class="text-[10px] font-black mb-5 px-3 py-1 rounded-full bg-amber-500 text-white uppercase tracking-widest">
                      -{pkg.discount}% OFF
                    </div>
                    <a
                      href={`https://wa.me/${WA}?text=${waMsg}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-whatsapp py-1.5 px-4 text-[11px] font-black uppercase tracking-wider"
                    >
                      <WhatsAppIcon className="w-3.5 h-3.5 shrink-0" />
                      Book Now
                    </a>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="mb-10 p-10 bg-emerald-900 text-white text-center">
    <h3 class="text-3xl font-bold mb-3 font-heading">Need a Custom Package?</h3>
    <p class="mb-8 text-lg max-w-xl mx-auto text-white/80">
      Talk to our team and we'll create a personalised health panel tailored to
      your specific needs and budget.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href={`https://wa.me/${WA}?text=Hello`}
        class="btn-whatsapp w-full sm:w-auto px-10"
      >
        <WhatsAppIcon />
        Book on WhatsApp
      </a>
      <a
        href="tel:+917006087182"
        class="btn-outline text-white border-white hover:bg-white/10 w-full sm:w-auto px-10 flex items-center justify-center gap-2"
      >
        <PhoneCall className="w-4 h-4" /> Call Now
      </a>
    </div>
  </section>
</Layout>
