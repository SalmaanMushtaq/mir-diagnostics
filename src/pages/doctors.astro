---
import WhatsAppIcon from "@/components/whatsapImg";
import Layout from "../layouts/Layout.astro";
import {
  BadgeCheck,
  CalendarDays,
  Clock,
  MoveRight,
  PhoneCall,
} from "lucide-react";

const WA = "917006087182";

const doctors = [
  {
    id: "dr-javid-magray",
    name: "Dr. Javid Magray",
    role: "Senior Radiologist",
    qualifications: "MBBS, MD (Radiology)",
    experience: "10+ years",
    specialties: [
      "USG & Doppler",
      "3D/4D Imaging",
      "Obstetric Ultrasound",
      "All Ultrasound Types",
    ],
    desc: "Dr. Javid Magray is the senior radiologist at Mir Diagnostics, Pampore. Specialising in all kinds of ultrasound imaging, he brings precision and compassionate care to every diagnosis.",
    days: "Every Day",
    timing: "By Appointment",
    img: "/dr-javid-magray.jpg",
    quote: "Precision in every image, care in every diagnosis.",
    highlight: true,
  },
  {
    id: "dr-musadiq-rafiq",
    name: "Dr. Musadiq Rafiq",
    role: "Radiologist",
    qualifications: "MBBS, MD",
    experience: "8+ years",
    specialties: [
      "Diagnostic Radiology",
      "Interventional USG",
      "CT Interpretation",
      "X-Ray Reporting",
    ],
    desc: "Dr. Musadiq Rafiq is a qualified radiologist with extensive experience in diagnostic radiology and ultrasound-guided procedures. He ensures accurate, timely reporting for all imaging investigations.",
    days: "Mon – Sat",
    timing: "9:00 AM – 4:00 PM",
    icon: "🩺",
    accent: "text-sky-700",
    bgAccent: "bg-sky-50",
    borderAccent: "border-sky-100",
    quote: "Every image tells a story — my job is to read it accurately.",
  },
  {
    id: "dr-m-arif",
    name: "Dr. M. Arif",
    role: "Sonologist",
    qualifications: "MBBS, DMRD",
    experience: "7+ years",
    specialties: [
      "Sonography",
      "Abdominal USG",
      "Pelvic USG",
      "Obstetric Scans",
    ],
    desc: "Dr. M. Arif is a dedicated sonologist specialising in abdominal, pelvic and obstetric ultrasound. His attention to detail and patient-centric approach ensures diagnostic clarity for every scan.",
    days: "Mon – Sat",
    timing: "10:00 AM – 5:00 PM",
    icon: "📡",
    accent: "text-cyan-600",
    bgAccent: "bg-cyan-50",
    borderAccent: "border-cyan-100",
    quote: "Clear imaging is the foundation of correct treatment.",
  },
  {
    id: "dr-aijaz-ahmad",
    name: "Dr. Aijaz Ahmad",
    role: "Gynaecologist",
    qualifications: "MBBS, MS (Gynaecology)",
    experience: "12+ years",
    specialties: [
      "Obstetrics & Gynaecology",
      "Antenatal Care",
      "High-Risk Pregnancy",
      "Infertility",
    ],
    desc: "Dr. Aijaz Ahmad is an experienced gynaecologist providing comprehensive women's healthcare including antenatal monitoring, high-risk pregnancy management, and gynaecological consultations.",
    days: "Mon, Wed, Fri",
    timing: "10:00 AM – 2:00 PM",
    icon: "👩‍⚕️",
    accent: "text-pink-600",
    bgAccent: "bg-pink-50",
    borderAccent: "border-pink-100",
    quote: "Women's health is at the heart of every family's wellbeing.",
  },
  {
    id: "dr-bashir-ahmad",
    name: "Dr. Bashir Ahmad",
    role: "Urologist",
    qualifications: "MBBS, DGO",
    experience: "15+ years",
    specialties: [
      "Gynaecology",
      "Maternal-Fetal Medicine",
      "Reproductive Health",
      "Menstrual Disorders",
    ],
    desc: "Dr. Bashir Ahmad brings over 15 years of experience in gynaecology and maternal-fetal medicine. He is known for his compassionate approach and expertise in complex gynaecological conditions.",
    days: "Tue, Thu, Sat",
    timing: "11:00 AM – 3:00 PM",
    icon: "🏥",
    accent: "text-rose-700",
    bgAccent: "bg-rose-50",
    borderAccent: "border-rose-100",
    quote: "Compassionate care begins with listening to every patient.",
  },
  {
    id: "dr-yasir-sultan",
    name: "Dr. Yasir Sultan",
    role: "Dermatologist",
    qualifications: "MBBS, MD (Dermatology)",
    experience: "9+ years",
    specialties: [
      "Dermatology",
      "Skin Disorders",
      "Cosmetic Dermatology",
      "Hair & Nail Disorders",
    ],
    desc: "Dr. Yasir Sultan is a board-certified dermatologist managing a wide spectrum of skin, hair and nail conditions. His expertise spans both medical dermatology and aesthetic skin treatments.",
    days: "Mon, Wed, Sat",
    timing: "10:00 AM – 3:00 PM",
    icon: "✨",
    accent: "text-violet-600",
    bgAccent: "bg-violet-50",
    borderAccent: "border-violet-100",
    quote: "Healthy skin reflects a healthy life.",
  },
  {
    id: "dr-altaf-hussain",
    name: "Dr. Altaf Hussain",
    role: "General Surgeon",
    qualifications: "MBBS, MS (General Surgery), MD",
    experience: "14+ years",
    specialties: [
      "General Surgery",
      "Laparoscopic Surgery",
      "Wound Management",
      "Hernia & Appendix",
    ],
    desc: "Dr. Altaf Hussain is a senior general surgeon with expertise in both open and laparoscopic surgical procedures. He handles a broad range of surgical conditions with precision and patient safety at the forefront.",
    days: "Mon – Fri",
    timing: "9:00 AM – 1:00 PM",
    icon: "🔬",
    accent: "text-emerald-700",
    bgAccent: "bg-emerald-50",
    borderAccent: "border-emerald-100",
    quote: "Surgical precision saves lives — every cut matters.",
  },
];
---

<Layout
  title="Our Doctors | Mir Diagnostics"
  description="Meet our expert medical team at Mir Diagnostics Pampore."
>
  <section class="pt-20 text-white bg-linear-to-br from-[#0D6B3A] to-[#065f46]">
    <div class="max-w-7xl mx-auto section-padding py-20">
      <span
        class="text-sm tracking-widest uppercase mb-3 block opacity-60 font-mono"
        >— Medical Team</span
      >
      <h1 class="text-5xl md:text-6xl font-bold mt-1 mb-4 font-heading">
        Our Doctors
      </h1>
      <p class="text-xl max-w-2xl leading-relaxed text-white/80">
        A team of 7+ experienced specialists serving Pampore and Kashmir with
        precision and care.
      </p>
      <div class="flex flex-wrap gap-2 mt-8">
        {
          doctors.map((d) => (
            <a
              href={`#${d.id}`}
              class="px-4 py-2 rounded-full text-xs font-bold border-2 border-white/25 text-white hover:bg-white/15 transition-all"
            >
              {d.name.split(" ").slice(0, 3).join(" ")}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="dr-javid-magray" class="scroll-mt-20 bg-white">
    <div class="max-w-7xl mx-auto section-padding">
      {
        (() => {
          const doc = doctors[0];
          const waMsg = encodeURIComponent(
            `Hello, I want to book a USG appointment with ${doc.name}.`,
          );
          return (
            <article class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
              <div class="relative group w-full">
                <div class="rounded-md md:rounded-lg overflow-hidden shadow-md border border-slate-100">
                  <img
                    src={doc.img}
                    alt={doc.name}
                    class="w-full object-cover object-top h-[500px] aspect-4/5"
                    loading="eager"
                  />
                </div>
                <div class="absolute top-5 right-5 bg-white/95 backdrop-blur-sm px-4 py-2 rounded-lg shadow-sm flex items-center gap-2 border border-slate-100">
                  <BadgeCheck className="w-4 h-4 text-emerald-500" />
                  <div>
                    <div class="text-xs font-black text-blue-900">
                      {doc.experience}
                    </div>
                    <div class="text-[10px] text-slate-500 uppercase font-bold tracking-tight">
                      Experience
                    </div>
                  </div>
                </div>
              </div>

              <div class="flex flex-col pt-4">
                <div class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-full mb-6 self-start bg-amber-50 text-amber-800 border border-amber-200">
                  ⭐ Featured Specialist
                </div>

                <h2 class="text-4xl md:text-5xl font-bold mb-2 font-heading text-blue-900">
                  {doc.name}
                </h2>
                <p class="text-xl font-bold mb-1 text-emerald-700">
                  {doc.role}
                </p>
                <p class="text-xs tracking-widest uppercase mb-6 font-mono text-slate-400">
                  {doc.qualifications}
                </p>

                <blockquote class="italic text-xl leading-relaxed pl-5 border-l-4 mb-6 font-heading text-blue-950 border-emerald-500">
                  "{doc.quote}"
                </blockquote>

                <p class="leading-relaxed mb-6 text-base text-slate-600">
                  {doc.desc}
                </p>

                <div class="flex flex-wrap gap-2 mb-6">
                  {doc.specialties.map((s) => (
                    <span class="text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-100">
                      {s}
                    </span>
                  ))}
                </div>

                <div class="rounded-xl p-5 border bg-slate-50 border-slate-100 mb-8">
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex items-start gap-3">
                      <div class="p-2 bg-white rounded-lg shadow-sm shrink-0">
                        <CalendarDays className="w-4 h-4 text-emerald-600" />
                      </div>
                      <div>
                        <div class="text-[10px] font-bold uppercase tracking-wider mb-0.5 text-emerald-600">
                          Visiting Days
                        </div>
                        <div class="font-black text-sm uppercase text-blue-900">
                          {doc.days}
                        </div>
                      </div>
                    </div>
                    <div class="flex items-start gap-3">
                      <div class="p-2 bg-white rounded-lg shadow-sm shrink-0">
                        <Clock className="w-4 h-4 text-emerald-600" />
                      </div>
                      <div>
                        <div class="text-[10px] font-bold uppercase tracking-wider mb-0.5 text-emerald-600">
                          Timing
                        </div>
                        <div class="font-black text-sm uppercase text-blue-900">
                          {doc.timing}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="flex flex-wrap gap-3 flex-col md:flex-row">
                  <a
                    href={`https://wa.me/${WA}?text=${waMsg}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-whatsapp flex-1 sm:flex-none px-8 py-3 justify-center"
                  >
                    <WhatsAppIcon /> Book Appointment
                  </a>
                  <a href="tel:+917006087182" class="btn-outline">
                    <PhoneCall className="w-4 h-4 mr-2" /> Call Centre
                  </a>
                </div>
              </div>
            </article>
          );
        })()
      }
    </div>
  </section>

  <section class="scroll-mt-20 bg-linear-to-br from-slate-50 to-emerald-50">
    <div class="max-w-7xl mx-auto section-padding">
      <div class="text-center mb-14">
        <span class="section-tag">Full Team</span>
        <h2 class="section-title">Our Specialist Panel</h2>
        <p class="section-subtitle mx-auto text-slate-500">
          Experienced consultants across multiple disciplines available at Mir
          Diagnostics.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-7">
        {
          doctors.slice(1).map((doc) => {
            const waMsg = encodeURIComponent(
              `Hello, I want to book an appointment with ${doc.name}.`,
            );
            return (
              <article
                id={doc.id}
                class="bg-white rounded-md md:rounded-lg overflow-hidden border border-slate-100 shadow-sm hover:shadow-md transition-all scroll-mt-24 flex flex-col"
              >
                <div
                  class={`flex items-center gap-5 p-6 pb-5 bg-opacity-10 ${doc.bgAccent}`}
                >
                  <div
                    class={`w-16 h-16 rounded-md  flex items-center justify-center text-3xl shadow-sm shrink-0 bg-white border ${doc.borderAccent}`}
                  >
                    {doc.icon}
                  </div>
                  <div>
                    <h3
                      class={`text-lg font-bold leading-tight font-heading ${doc.accent}`}
                    >
                      {doc.name}
                    </h3>
                    <p class="text-xs font-bold mt-0.5 text-slate-700">
                      {doc.role}
                    </p>
                    <p class="text-[10px] mt-0.5 font-mono text-slate-400 uppercase tracking-tighter">
                      {doc.qualifications}
                    </p>
                  </div>
                </div>

                <div class="px-6 pb-6 flex flex-col flex-1">
                  <blockquote
                    class={`italic text-xs pl-3 border-l-2 mb-4 leading-relaxed text-slate-500 ${doc?.accent?.replace("text", "border")}`}
                  >
                    "{doc.quote}"
                  </blockquote>

                  <p class="text-sm leading-relaxed mb-4 text-slate-600">
                    {doc.desc}
                  </p>

                  <div class="flex flex-wrap gap-1.5 mb-5">
                    {doc.specialties.map((s) => (
                      <span
                        class={`text-[9px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-lg border ${doc.bgAccent} ${doc.accent} ${doc.borderAccent}`}
                      >
                        {s}
                      </span>
                    ))}
                  </div>

                  <div class="rounded-md p-4 mb-5 flex items-center gap-4 bg-slate-50 border border-slate-100">
                    <div class="text-center shrink-0">
                      <div class="text-[9px] font-black uppercase text-slate-400 tracking-wider mb-0.5">
                        Days
                      </div>
                      <div class={`text-[11px] font-bold ${doc.accent}`}>
                        {doc.days}
                      </div>
                    </div>
                    <div class="w-px h-8 bg-slate-200 shrink-0" />
                    <div>
                      <div class="text-[9px] font-black uppercase text-slate-400 tracking-wider mb-0.5">
                        Timing
                      </div>
                      <div class={`text-[11px] font-bold ${doc.accent}`}>
                        {doc.timing}
                      </div>
                    </div>
                    <div class="ml-auto shrink-0 text-right">
                      <div class="text-[9px] font-black uppercase text-slate-400 tracking-wider mb-0.5">
                        Exp.
                      </div>
                      <div class={`text-[11px] font-bold ${doc.accent}`}>
                        {doc.experience}
                      </div>
                    </div>
                  </div>

                  <div class="flex gap-2 mt-auto">
                    <a
                      href={`https://wa.me/${WA}?text=${waMsg}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-whatsapp flex-1 justify-center py-2 text-xs"
                    >
                      <WhatsAppIcon className="w-3.5 h-3.5" /> Book Now
                    </a>
                    <a href="tel:+917006087182" class="btn-outline py-2 px-4">
                      <PhoneCall className="w-4 h-4 text-slate-400" />
                    </a>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="section-padding bg-emerald-950 text-white text-center mb-10">
    <div class="max-w-3xl mx-auto px-4">
      <h3 class="text-3xl md:text-4xl font-bold mb-4 font-heading">
        Advanced Diagnostic Imaging
      </h3>
      <p class="text-lg mb-10 text-white/70">
        Equipped with high-resolution technology to ensure early detection and
        accurate results for every patient.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`https://wa.me/${WA}?text=Inquiry`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp px-10"
        >
          <WhatsAppIcon /> WhatsApp Booking
        </a>
        <a
          href="/services"
          class="btn-outline text-white border-white hover:bg-white/10 px-10 flex items-center gap-2"
        >
          View All Services <MoveRight className="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>
</Layout>
