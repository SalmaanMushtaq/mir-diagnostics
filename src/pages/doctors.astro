---
import Layout from "../layouts/Layout.astro";
import {
  Stethoscope,
  Award,
  Clock,
  Calendar,
  MessageCircle,
  Phone,
  Star,
  Quote,
  ArrowRight,
} from "lucide-react";

const WA = "917006087182";

const doctors = [
  {
    id: "dr-javid-magray",
    name: "Dr. Javid Magray",
    role: "Senior Radiologist",
    qualifications: "MBBS, MD (Radiology)",
    experience: "10+ years",
    specialties: [
      "USG & Doppler",
      "3D/4D Imaging",
      "Obstetric Ultrasound",
      "All Ultrasound Types",
    ],
    desc: "Dr. Javid Magray is the senior radiologist at Mir Diagnostics, Pampore. Specialising in all kinds of ultrasound imaging, he brings precision and compassionate care to every diagnosis. Available every Sunday at the centre.",
    days: "Every Sunday",
    timing: "By Appointment",
    img: "/dr-javid-magray.jpg",
    quote: "Precision in every image, care in every diagnosis.",
    highlight: true,
  },
];
---

<Layout
  title="Our Doctors | Mir Diagnostics"
  description="Meet Dr. Javid Magray — Senior Radiologist at Mir Diagnostics Pampore. Expert USG and Doppler services available every Sunday."
>
  <main id="main-content">
    <section
      class="pt-20 text-white"
      style="background: linear-gradient(135deg, #0D6B3A 0%, #065f46 100%)"
      aria-labelledby="doctors-hero-title"
    >
      <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
        <span
          class="text-sm tracking-widest uppercase mb-3 block opacity-70"
          style="font-family: var(--font-mono)">— Medical Team</span
        >
        <h1
          id="doctors-hero-title"
          class="text-5xl md:text-6xl font-bold mt-1 mb-4"
          style="font-family: var(--font-heading)"
        >
          Our Doctors
        </h1>
        <p class="text-xl max-w-2xl text-white/80 leading-relaxed">
          Expert specialists delivering accurate diagnostics with compassion at
          Mir Diagnostics, Pampore.
        </p>
      </div>
    </section>

    <section class="section-padding bg-white" aria-labelledby="team-heading">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <h2 id="team-heading" class="sr-only">Our Specialist Doctors</h2>

        {
          doctors.map((doc) => {
            const waMsg = encodeURIComponent(
              `Hello, I want to book a USG appointment with ${doc.name} at Mir Diagnostics, Pampore.`,
            );
            return (
              <article
                class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start mb-24"
                aria-labelledby={`doc-name-${doc.id}`}
              >
                <div class="relative group w-full">
                  <div class="rounded-4xl overflow-hidden shadow-2xl border border-gray-100 transition-transform duration-500 group-hover:scale-[1.01]">
                    <img
                      src={doc.img}
                      alt={`Portrait of ${doc.name}, ${doc.role}`}
                      class="w-full h-full object-cover"
                      style="min-height: 500px; aspect-ratio: 4/5;"
                      loading="eager"
                    />
                  </div>

                  <div class="absolute top-6 right-6 bg-white/95 backdrop-blur-sm px-4 py-2 rounded-xl shadow-lg flex items-center gap-2 border border-emerald-50">
                    <Award
                      className="w-4 h-4 text-emerald-600"
                      aria-hidden="true"
                    />
                    <div>
                      <div class="text-[9px] uppercase tracking-widest font-bold text-gray-400 leading-none">
                        Experience
                      </div>
                      <div class="text-xs font-black text-emerald-900">
                        {doc.experience}
                      </div>
                    </div>
                  </div>
                </div>

                <div class="flex flex-col pt-4">
                  <div class="inline-flex items-center gap-2 bg-amber-50 text-amber-700 text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-full mb-6 border border-amber-100 self-start">
                    <Star
                      className="w-3.5 h-3.5 fill-amber-500 text-amber-500"
                      aria-hidden="true"
                    />
                    Featured Specialist
                  </div>

                  <header class="mb-6">
                    <h3
                      id={`doc-name-${doc.id}`}
                      class="text-4xl md:text-5xl font-bold mb-2 text-emerald-950"
                      style="font-family: var(--font-heading)"
                    >
                      {doc.name}
                    </h3>
                    <p class="text-xl font-bold text-emerald-600 mb-1">
                      {doc.role}
                    </p>
                    <p class="text-xs font-mono tracking-widest text-gray-400 uppercase">
                      {doc.qualifications}
                    </p>
                  </header>

                  <div class="relative mb-8 group">
                    <Quote
                      className="absolute -top-4 -left-4 w-10 h-10 text-emerald-50 rotate-180"
                      aria-hidden="true"
                    />
                    <blockquote
                      class="italic text-xl text-emerald-900 leading-relaxed pl-6 border-l-4 border-emerald-500"
                      style="font-family: var(--font-heading)"
                    >
                      "{doc.quote}"
                    </blockquote>
                  </div>

                  <p class="leading-relaxed mb-8 text-gray-600 text-lg">
                    {doc.desc}
                  </p>

                  <div
                    class="flex flex-wrap gap-2 mb-8"
                    aria-label="Specialties"
                  >
                    {doc.specialties.map((s) => (
                      <span class="text-[11px] font-bold uppercase tracking-wider px-4 py-2 rounded-xl bg-emerald-50 text-emerald-700 border border-emerald-100">
                        {s}
                      </span>
                    ))}
                  </div>

                  <div class="bg-emerald-50/50 rounded-2xl p-6 border border-emerald-100 mb-10">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                      <div class="flex items-start gap-3">
                        <div class="p-2 bg-white rounded-lg shadow-sm">
                          <Calendar
                            className="w-5 h-5 text-emerald-600"
                            aria-hidden="true"
                          />
                        </div>
                        <div>
                          <div class="text-[10px] uppercase font-bold text-emerald-500 tracking-wider">
                            Visiting Days
                          </div>
                          <div class="text-sm font-black text-emerald-900 uppercase">
                            {doc.days}
                          </div>
                        </div>
                      </div>
                      <div class="flex items-start gap-3">
                        <div class="p-2 bg-white rounded-lg shadow-sm">
                          <Clock
                            className="w-5 h-5 text-emerald-600"
                            aria-hidden="true"
                          />
                        </div>
                        <div>
                          <div class="text-[10px] uppercase font-bold text-emerald-500 tracking-wider">
                            Timing
                          </div>
                          <div class="text-sm font-black text-emerald-900 uppercase">
                            {doc.timing}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="flex flex-wrap gap-4">
                    <a
                      href={`https://wa.me/${WA}?text=${waMsg}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-whatsapp px-8 py-2 shadow-lg shadow-emerald-100 flex items-center justify-center gap-3 text-base flex-1 sm:flex-none"
                    >
                      <MessageCircle className="w-5 h-5" /> Book Appointment
                    </a>
                    <a
                      href="tel:+917006087182"
                      class="btn-outline px-8 py-2 flex rounded-full items-center justify-center gap-3 text-base border-emerald-100 text-emerald-800 hover:bg-emerald-50 flex-1 sm:flex-none"
                    >
                      <Phone className="w-4 h-4" /> Call Center
                    </a>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </section>
    <section
      class="section-padding my-16 rounded-3xl p-10 text-white text-center shadow-2xl bg-linear-to-br from-emerald-800 to-emerald-600"
      aria-labelledby="advance-diagnostic-imaging"
    >
      {/* Glassy Background Ornament */}
      <!-- <div
        class="absolute -top-24 -right-24 w-64 h-64 bg-white/10 rounded-full blur-3xl transition-transform duration-700 group-hover:scale-150"
        aria-hidden="true"
      >
      </div> -->

      <div class="relative z-10">
        <h3
          id="usg-banner-title"
          class="text-3xl md:text-4xl font-bold mb-4"
          style="font-family: var(--font-heading)"
        >
          Advanced Diagnostic Imaging
        </h3>
        <p class="text-lg max-w-2xl mx-auto mb-10 text-emerald-50/80">
          Our imaging department is equipped with high-resolution technology to
          ensure early detection and accurate results for every patient.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="/services#usg"
            class="bg-white text-emerald-900 font-bold px-10 py-3 rounded-full transition-all hover:bg-emerald-50 hover:shadow-xl focus:ring-4 focus:ring-white/30 flex items-center gap-2"
          >
            View Services <ArrowRight className="w-4 h-4" />
          </a>
          <a
            href={`https://wa.me/${WA}?text=USG%20Inquiry`}
            target="
              _blank"
            rel="noopener noreferrer"
            class="bg-emerald-800/30 backdrop-blur-md border border-white/20 text-white font-bold px-10 py-3 rounded-full transition-all hover:bg-emerald-800/50 flex items-center gap-3"
          >
            <MessageCircle className="w-5 h-5" /> WhatsApp Booking
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
