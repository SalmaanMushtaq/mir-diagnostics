---
import WhatsAppIcon from "@/components/whatsapImg";
import {
  Activity,
  ArrowRight,
  Check,
  Clock,
  MoveRight,
  Phone,
  PhoneCall,
  PhoneForwarded,
  Sparkles,
  Stethoscope,
} from "lucide-react";
import HeroCarousel from "../components/HeroCarousel";
import Layout from "../layouts/Layout.astro";

const WA = "917006087182";

const packages = [
  {
    id: "bp11",
    name: "Body Profile 1.1",
    price: 600,
    originalPrice: 1200,
    highlight: false,
    img: "/pkg-profile11-600.jpg",
    tests: [
      "Thyroid Profile",
      "CBC",
      "Lipid Profile",
      "KFT",
      "LFT",
      "Calcium",
      "Electrolytes",
    ],
  },
  {
    id: "bp12b",
    name: "Body Profile 1.3",
    price: 1499,
    originalPrice: 3000,
    highlight: true,
    img: "/pkg-profile12-1499.jpg",
    tests: [
      "Thyroid Profile",
      "CBC",
      "Lipid Profile",
      "KFT",
      "LFT",
      "Calcium",
      "Electrolytes",
      "HbA1c",
      "Vitamin D",
      "Vitamin B12",
      "Testosterone",
    ],
  },
  {
    id: "bp12a",
    name: "Body Profile 1.2",
    price: 999,
    originalPrice: 2000,
    highlight: false,
    img: "/pkg-profile12-999.jpg",
    tests: [
      "Thyroid Profile",
      "CBC",
      "Lipid Profile",
      "KFT",
      "LFT",
      "Calcium",
      "Electrolytes",
      "HbA1c",
      "Iron Profile",
    ],
  },

  // {
  //   id: "bp3",
  //   name: "Body Profile 3",
  //   price: 1499,
  //   originalPrice: 3500,
  //   highlight: false,
  //   img: "/body-profile-3.jpg",
  //   tests: [
  //     "Vitamin D3",
  //     "Vitamin B12",
  //     "Testosterone",
  //     "Thyroid Profile",
  //     "HbA1c",
  //     "Iron Profile",
  //     "CBC",
  //     "ESR",
  //     "Lipid Profile",
  //     "LFT",
  //     "Electrolytes",
  //   ],
  // },
];

const contactStats = [
  {
    num: "7006087182",
    label: "Call / WhatsApp",
    href: `tel:+91${WA}`,
    icon: Phone,
  },
  {
    num: "7006279232",
    label: "Alternate Number",
    href: "tel:+917006279232",
    icon: PhoneForwarded,
  },
  { num: "Mon–Sat", label: "Lab Timings", href: null, icon: Clock },
  {
    num: "Sunday",
    label: "Dr. Javid Magray (USG)",
    href: "/services#usg",
    icon: Stethoscope,
  },
];
---

<Layout title="Home | Mir Diagnostics Pampore">
  <main id="main-content">
    <HeroCarousel client:load />
    <!-- Quick Contact Information Section -->
    <section class="bg-white border-b" aria-label="Quick Contact Information">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
          {
            contactStats.map((s) => {
              const Icon = s.icon;
              return (
                <div class="py-6 px-4 text-center">
                  {s.href ? (
                    <a
                      href={s.href}
                      class="group block focus:outline-none focus:ring-2 focus:ring-emerald-500 rounded-lg p-1"
                    >
                      <Icon
                        className="w-5 h-5 mx-auto mb-2 text-emerald-600 group-hover:scale-110 transition-transform"
                        strokeWidth={2.5}
                        aria-hidden="true"
                      />
                      <div
                        class="font-bold text-lg md:text-xl text-emerald-900 group-hover:text-emerald-700 transition-colors"
                        style="font-family: var(--font-heading);"
                      >
                        {s.num}
                      </div>
                      <div class="text-[10px] mt-1 text-gray-500 uppercase tracking-widest font-medium">
                        {s.label}
                      </div>
                    </a>
                  ) : (
                    <div>
                      <Icon
                        className="w-5 h-5 mx-auto mb-2 text-emerald-600"
                        strokeWidth={2.5}
                        aria-hidden="true"
                      />
                      <div
                        class="font-bold text-lg md:text-xl text-emerald-900"
                        style="font-family: var(--font-heading);"
                      >
                        {s.num}
                      </div>
                      <div class="text-[10px] mt-1 text-gray-500 uppercase tracking-widest font-medium">
                        {s.label}
                      </div>
                    </div>
                  )}
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- Packages Title Section -->
    <section
      class="section-padding relative overflow-hidden bg-linear-to-b from-emerald-50 via-white to-emerald-50"
      aria-labelledby="packages-title"
    >
      <article class="container-tight relative z-10">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <span
            class="inline-flex items-center rounded-full border border-emerald-200 bg-white px-4 py-2 text-[11px] font-extrabold uppercase tracking-[0.24em] text-emerald-700 shadow-sm"
          >
            Special Offers
          </span>

          <h2 id="packages-title" class="section-title mt-5 text-emerald-950">
            Health Test Packages
          </h2>

          <p class="section-subtitle mx-auto mt-4 text-emerald-900/70">
            Affordable diagnostic packages from Mir Diagnostics Pampore with
            fast processing, trusted reporting, and instant WhatsApp booking.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            packages.map((pkg) => {
              const waMsg = encodeURIComponent(
                `Hello, I want to book *${pkg.name}* (₹${pkg.price}) at Mir Diagnostics.`,
              );

              const discount = Math.round(
                (1 - pkg.price / pkg.originalPrice) * 100,
              );

              return (
                <section
                  class={`group relative flex h-full flex-col overflow-hidden rounded-xl md:rounded-2xl border bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${
                    pkg.highlight
                      ? "border-emerald-500 ring-1 ring-emerald-200 lg:scale-105"
                      : "border-emerald-100"
                  }`}
                  aria-labelledby={`pkg-name-${pkg.id}`}
                >
                  {pkg.highlight && (
                    <div class="absolute inset-x-0 top-0 h-1 bg-linear-to-r from-emerald-500 via-green-500 to-emerald-400" />
                  )}

                  <div class="relative">
                    <div class="aspect-16/10 overflow-hidden">
                      <img
                        src={pkg.img}
                        alt={pkg.name}
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    </div>

                    <div class="absolute inset-0 bg-linear-to-t from-emerald-950/30 via-transparent to-transparent" />

                    <div class="absolute left-4 top-4 flex items-center gap-2">
                      <span class="rounded-full bg-emerald-600 px-3 py-1 text-[11px] font-black text-white shadow">
                        {discount}% OFF
                      </span>

                      {pkg.highlight && (
                        <span class="inline-flex items-center gap-1 rounded-full bg-white/95 px-3 py-1 text-[11px] font-black text-amber-600 shadow">
                          <Sparkles className="h-3.5 w-3.5 fill-current" />
                          Most Popular
                        </span>
                      )}
                    </div>
                  </div>

                  <div class="flex flex-1 flex-col p-6">
                    <div class="mb-4">
                      <div class="mb-3 flex items-center gap-2 text-emerald-700">
                        <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-emerald-50">
                          <Activity className="h-4 w-4" />
                        </span>
                        <span class="text-[11px] font-bold uppercase tracking-[0.18em] text-emerald-700/80">
                          Full Screening Panel
                        </span>
                      </div>

                      <h3
                        id={`pkg-name-${pkg.id}`}
                        class="text-xl font-extrabold leading-tight text-emerald-950 transition-colors group-hover:text-emerald-700"
                        style="font-family: var(--font-heading);"
                      >
                        {pkg.name}
                      </h3>
                    </div>

                    <div class="mb-6 rounded-lg md:rounded-xl border border-emerald-100 bg-emerald-50/50 p-4">
                      <p class="mb-3 text-[11px] font-bold uppercase tracking-[0.16em] text-emerald-800/70">
                        Included Tests
                      </p>

                      <ul
                        class="grid grid-cols-1 gap-2 sm:grid-cols-2"
                        aria-label={`Tests included in ${pkg.name}`}
                      >
                        {pkg.tests.slice(0, 6).map((t) => (
                          <li class="flex items-start gap-2 text-sm leading-snug text-gray-700">
                            <Check
                              className="mt-0.5 h-4 w-4 shrink-0 text-emerald-600"
                              strokeWidth={3}
                              aria-hidden="true"
                            />
                            <span>{t}</span>
                          </li>
                        ))}
                      </ul>

                      {pkg.tests.length > 6 && (
                        <p class="mt-3 text-xs font-medium text-emerald-700/75">
                          +{pkg.tests.length - 6} more tests included
                        </p>
                      )}
                    </div>

                    <div class="mt-auto">
                      <div class="mb-5 flex items-end justify-between gap-4">
                        <div>
                          <p class="mb-1 text-xs font-semibold uppercase tracking-[0.14em] text-emerald-800/60">
                            Offer Price
                          </p>
                          <div class="flex items-baseline gap-2">
                            <span
                              class="text-3xl font-black text-emerald-950"
                              style="font-family: var(--font-heading);"
                            >
                              ₹{pkg.price.toLocaleString()}
                            </span>
                            <del class="text-sm font-medium text-gray-400">
                              ₹{pkg.originalPrice.toLocaleString()}
                            </del>
                          </div>
                        </div>

                        <div class="rounded-2xl bg-emerald-50 px-3 py-2 text-right">
                          <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-emerald-700/70">
                            You Save
                          </p>
                          <p class="text-sm font-extrabold text-emerald-700">
                            ₹{(pkg.originalPrice - pkg.price).toLocaleString()}
                          </p>
                        </div>
                      </div>

                      <a
                        href={`https://wa.me/${WA}?text=${waMsg}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class={`inline-flex w-full items-center justify-center gap-2 rounded-3xl px-5 py-3.5 text-sm font-bold transition-all duration-300 ${
                          pkg.highlight
                            ? "bg-emerald-600 text-white shadow-lg shadow-emerald-200 hover:bg-emerald-700"
                            : "bg-emerald-950 text-white hover:bg-emerald-800"
                        }`}
                      >
                        <WhatsAppIcon />
                        Book on WhatsApp
                      </a>
                    </div>
                  </div>
                </section>
              );
            })
          }
        </div>

        <div class="mt-12 text-center">
          <a
            href="/services#packages"
            class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white px-8 py-3.5 text-sm font-bold text-emerald-900 shadow-sm transition-all hover:border-emerald-500 hover:bg-emerald-50"
          >
            View All Packages
            <ArrowRight
              className="h-4 w-4 transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>
      </article>
    </section>
    <!-- Home Collection Section -->
    <section
      class="py-16 bg-emerald-900 text-white"
      aria-labelledby="home-collection-title"
    >
      <div class="container-tight px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <span
              class="text-emerald-400 text-xs font-mono tracking-widest uppercase mb-2 block"
              aria-hidden="true">— Pampore & Surrounding Areas</span
            >
            <h2
              id="home-collection-title"
              class="text-3xl md:text-4xl font-bold mb-4"
              style="font-family: var(--font-heading);"
            >
              Blood Test at Home in Pampore
            </h2>
            <p class="mb-8 text-emerald-100/80 leading-relaxed">
              We come to you — sample collection at your doorstep. Available
              across <strong>Pampore, Khrew, Namblabal</strong> and nearby areas.
            </p>
            <div class="flex flex-wrap gap-4">
              <a
                href={`https://wa.me/${WA}?text=Home%20Collection%20Request`}
                class="btn-whatsapp px-8 w-60 justify-center"
              >
                <WhatsAppIcon />
                Book Home Collection</a
              >
              <a
                href="tel:+917006087182"
                class="w-60 border-2 justify-center border-white/30 hover:bg-white/10 px-8 py-3 rounded-full font-bold transition-all flex items-center gap-2 focus:ring-2 focus:ring-white"
              >
                <PhoneCall className="w-4 h-4 text-emerald-400" /> 7006087182
              </a>
            </div>
          </div>
          <div
            class="rounded-2xl overflow-hidden shadow-2xl border-4 border-white/10"
          >
            <img
              src="/home-collection-pampore.jpg"
              alt="Healthcare professional performing home blood sample collection"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>
    <!-- Doctor Title Section -->
    <section class="section-padding bg-white" aria-labelledby="doctor-title">
      <div class="container-tight">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="rounded-2xl overflow-hidden shadow-md">
            <img
              src="/dr-javid-magray.jpg"
              alt="Dr. Javid Magray — Senior Radiologist"
              class="w-full object-cover"
              loading="lazy"
            />
          </div>
          <div>
            <span class="section-tag">Every Sunday</span>
            <h2 id="doctor-title" class="section-title mb-1">
              Dr. Javid Magray
            </h2>
            <p class="text-lg font-semibold mb-4 text-emerald-700">
              Senior Radiologist
            </p>
            <blockquote
              class="italic text-xl mb-8 pl-6 border-l-4 border-emerald-500 text-emerald-900 font-medium"
            >
              "Precision in every image, care in every diagnosis."
            </blockquote>
            <ul class="space-y-3 mb-8">
              {
                [
                  "Advanced Imaging",
                  "Accurate Reports",
                  "Compassionate Care",
                  "All kinds of Ultrasounds Available",
                ].map((f) => (
                  <li class="flex items-center gap-3 text-sm font-medium text-gray-800">
                    <Check
                      className="w-5 h-5 text-emerald-500"
                      aria-hidden="true"
                    />{" "}
                    {f}
                  </li>
                ))
              }
            </ul>
            <div
              class="p-5 rounded-xl bg-emerald-50 border border-emerald-100 mb-8"
            >
              <p class="text-sm font-bold text-emerald-900">
                📅 Available every Sunday at Mir Diagnostics
              </p>
              <p class="text-xs text-emerald-700 mt-1">
                Khrew Bus Stop, Namblabal, Pampore
              </p>
            </div>
            <div class="flex flex-wrap gap-4">
              <a
                href={`https://wa.me/${WA}?text=USG%20Appointment`}
                class="btn-whatsapp"
              >
                <WhatsAppIcon />
                Book USG Appointment</a
              >
              <a href="/services#usg" class="btn-outline rounded-3xl"
                >View USG Services <MoveRight className="w-5 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- USG Facilities Section -->
    <section
      class="section-padding bg-emerald-50/50"
      aria-labelledby="usg-title"
    >
      <div class="container-tight">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="section-tag">Imaging Centre</span>
            <h2 id="usg-title" class="section-title mb-6">
              USG Facilities Available
            </h2>
            <div class="grid grid-cols-2 gap-3 mb-8">
              {
                [
                  "3D/4D Ultrasounds",
                  "USG Abdomen",
                  "USG Pelvic Organs",
                  "USG Chest",
                  "Obstetric Ultrasound",
                  "Dating & Cardiac Scan",
                  "NT/NB Scan",
                  "Level-II Scan (Fetal)",
                  "Doppler",
                  "High Resolution",
                  "USG Scrotum",
                  "MSK USG",
                  "USG Neck",
                ].map((f) => (
                  <div class="flex items-center gap-2 text-xs py-2 px-3 rounded-lg bg-white border border-gray-100 shadow-sm">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0" />{" "}
                    {f}
                  </div>
                ))
              }
            </div>
            <a href="/services#usg" class="btn-primary inline-block rounded-3xl"
              >Book USG Scan</a
            >
          </div>
          <div class="rounded-xl md:rounded-2xl overflow-hidden shadow-md">
            <img
              src="/usg-facilities.jpg"
              alt="Advanced USG diagnostic equipment"
              class="w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- WHy Section -->
    <section class="section-padding bg-emerald-900 text-white">
      <div class="container-tight">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <span
              class="text-emerald-400 text-xs font-mono tracking-widest uppercase mb-3 block"
              >— Why Mir Diagnostics</span
            >
            <h2
              class="text-4xl md:text-5xl font-bold leading-tight mb-6"
              style="font-family: var(--font-heading);"
            >
              Your Health, Our Priority
            </h2>
            <p class="text-lg text-emerald-100/80 mb-8 leading-relaxed">
              Serving Pampore and the Kashmir Valley with accurate, affordable
              diagnostics. Our lab is equipped with modern instruments operated
              by qualified professionals.
            </p>
            <div class="grid grid-cols-2 gap-4 mb-10">
              {
                [
                  {
                    icon: "⚡",
                    title: "Fast Reports",
                    desc: "Most results same day",
                  },
                  {
                    icon: "🏠",
                    title: "Home Collection",
                    desc: "Across Pampore & Khrew",
                  },
                  {
                    icon: "📡",
                    title: "USG Every Sunday",
                    desc: "Dr. Javid Magray",
                  },
                  {
                    icon: "💚",
                    title: "Affordable",
                    desc: "Packages from ₹600",
                  },
                ].map((f) => (
                  <div class="rounded-xl p-4 bg-white/5 border border-white/10">
                    <div class="text-2xl mb-2" aria-hidden="true">
                      {f.icon}
                    </div>
                    <h4 class="font-bold text-sm text-white">{f.title}</h4>
                    <p class="text-xs text-white/50 mt-1">{f.desc}</p>
                  </div>
                ))
              }
            </div>
            <a
              href="/about"
              class="btn-outline border-white text-white hover:bg-white/10"
              >About Our Lab &rarr;</a
            >
          </div>
          <div
            class="rounded-2xl overflow-hidden shadow-2xl border-8 border-white/5"
          >
            <img
              src="/lab-reception.jpg"
              alt="Reception area of Mir Diagnostic Centre"
              class="w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Book Your Test -->
    <section class="py-20 container-tight md:px-4">
      <div
        class="md:rounded-3xl p-6 md:p-10 text-white text-center shadow-2xl bg-linear-to-br from-emerald-800 to-emerald-600"
      >
        <h2
          class="text-3xl font-bold mb-4"
          style="font-family: var(--font-heading);"
        >
          Book Your Test Today
        </h2>
        <address class="not-italic mb-2 text-emerald-100/90">
          Khrew Bus Stop, Namblabal, Pampore — J&K 192121
        </address>
        <p class="mb-8 text-sm text-emerald-100/80">
          Mon–Sat: Lab open · Sunday: USG with Dr. Javid Magray
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href={`https://wa.me/${WA}?text=Hello`}
            class="btn-whatsapp px-10 py-3 text-lg"
          >
            <WhatsAppIcon />
            Book on WhatsApp
          </a>
          <a
            href="tel:+917006087182"
            class="border-2 border-white/30 hover:bg-white/10 px-10 py-3 rounded-full font-bold transition-all flex items-center gap-2"
          >
            <PhoneCall className="w-4 h-4" /> Call Now
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
