---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us" description="Learn about Mir Diagnostics – our mission, values, and state-of-the-art laboratory services in Srinagar.">
  <!-- Page Hero -->
  <div class="pt-20 bg-gradient-to-br from-[#0D6B3A] to-[#16A34A] text-white">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
      <span class="font-mono text-white/60 text-sm tracking-widest uppercase">— Our Story</span>
      <h1 class="font-heading text-5xl md:text-6xl font-bold mt-3 mb-4">About Mir Diagnostics</h1>
      <p class="text-white/75 text-xl max-w-2xl">Committed to excellence in medical diagnostics, serving the people of Kashmir with precision, care, and integrity.</p>
    </div>
  </div>

  <!-- Mission & Vision -->
  <section class="section-padding">
    <div class="container-tight">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="section-tag">Who We Are</span>
          <h2 class="section-title">A Lab Built on Trust</h2>
          <p class="text-muted-foreground leading-relaxed mt-4 mb-6">
            Founded over a decade ago, Mir Diagnostics has grown to become one of the most trusted diagnostic centers in the Kashmir Valley. Our laboratory is equipped with state-of-the-art instruments operated by qualified scientists and technicians who are dedicated to delivering accurate and timely results.
          </p>
          <p class="text-muted-foreground leading-relaxed mb-8">
            We believe that access to quality diagnostic services is a fundamental right. That is why we strive to offer world-class testing at affordable prices, backed by a team of experienced pathologists and radiologists.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="btn-primary">Book an Appointment</a>
            <a href="/doctors" class="btn-outline">Meet Our Team</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { icon: "🎯", title: "Our Mission", desc: "To provide accurate, reliable, and timely diagnostic services that empower physicians and patients to make the best health decisions." },
            { icon: "🌟", title: "Our Vision", desc: "To be the most trusted and comprehensive diagnostic lab in the Kashmir Valley, setting the standard for quality care." },
            { icon: "💡", title: "Innovation", desc: "Continuously adopting the latest medical technologies and methodologies to improve diagnostic accuracy." },
            { icon: "🤝", title: "Patient Care", desc: "Treating every patient with respect, empathy, and the highest standards of professional service." },
          ].map((v) => (
            <div class="bg-lab-light rounded-xl p-5 border border-border">
              <div class="text-3xl mb-3">{v.icon}</div>
              <h4 class="font-heading font-semibold text-[#0D6B3A] mb-2">{v.title}</h4>
              <p class="text-muted-foreground text-sm leading-relaxed">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Tests & Services -->
  <section class="section-padding bg-lab-light">
    <div class="container-tight">
      <div class="text-center mb-14">
        <span class="section-tag">Services</span>
        <h2 class="section-title">Our Laboratory Tests</h2>
        <p class="section-subtitle mx-auto">We offer over 500 diagnostic tests across all major medical specialties.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { cat: "Hematology", tests: ["Complete Blood Count (CBC)", "ESR", "Peripheral Blood Smear", "Reticulocyte Count", "Coagulation Profile"] },
          { cat: "Biochemistry", tests: ["Liver Function Tests", "Kidney Function Tests", "Lipid Profile", "Blood Sugar / HbA1c", "Thyroid Panel"] },
          { cat: "Microbiology", tests: ["Urine Culture", "Blood Culture", "Stool Culture", "AFB Smear / Culture", "Sensitivity Testing"] },
          { cat: "Serology / Immunology", tests: ["HIV, HBsAg, HCV", "Dengue NS1 / IgM", "Widal Test", "TORCH Profile", "ANA & Rheumatoid Factor"] },
          { cat: "Molecular (PCR)", tests: ["COVID-19 RT-PCR", "HBV / HCV DNA Quantification", "TB-PCR", "HPV Genotyping", "Flu A/B Panel"] },
          { cat: "Hormones & Endocrinology", tests: ["TSH, T3, T4", "FSH / LH / Prolactin", "Testosterone / Estradiol", "Cortisol", "Insulin Level"] },
        ].map((c) => (
          <div class="bg-white rounded-2xl border border-border p-6 card-hover">
            <h3 class="font-heading text-xl font-semibold text-[#0D6B3A] mb-4 pb-3 border-b border-border">{c.cat}</h3>
            <ul class="space-y-2">
              {c.tests.map((t) => (
                <li class="flex items-center gap-2 text-sm text-muted-foreground">
                  <span class="w-1.5 h-1.5 rounded-full bg-lab-teal shrink-0" />
                  {t}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accreditations -->
  <section class="section-padding">
    <div class="container-tight">
      <div class="text-center mb-12">
        <span class="section-tag">Certifications</span>
        <h2 class="section-title">Accreditations & Standards</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {["NABL Accredited", "ISO 15189:2022", "CAP Certified", "Government Empanelled"].map((a) => (
          <div class="text-center p-6 bg-white rounded-2xl border-2 border-lab-blue/10 hover:border-lab-teal transition-colors card-hover">
            <div class="w-12 h-12 rounded-full bg-[#16A34A]/10 flex items-center justify-center mx-auto mb-3">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth={2} class="w-6 h-6 text-[#16A34A]">
                <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" strokeLinecap="round" strokeLinejoin="round"/>
              </svg>
            </div>
            <div class="font-heading font-semibold text-[#0D6B3A] text-sm">{a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
