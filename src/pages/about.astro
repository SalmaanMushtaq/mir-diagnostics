---
import Layout from "../layouts/Layout.astro";
import {
  Target,
  Sparkles,
  Lightbulb,
  Handshake,
  ArrowRight,
  ShieldCheck,
  ChevronRight,
} from "lucide-react";

const values = [
  {
    icon: Target,
    title: "Our Mission",
    desc: "To provide accurate, reliable, and timely diagnostic services that empower physicians and patients to make the best health decisions.",
    color: "text-emerald-600",
  },
  {
    icon: Sparkles,
    title: "Our Vision",
    desc: "To be the most trusted and comprehensive diagnostic lab in the Kashmir Valley, setting the standard for quality care.",
    color: "text-amber-500",
  },
  {
    icon: Lightbulb,
    title: "Innovation",
    desc: "Continuously adopting the latest medical technologies and methodologies to improve diagnostic accuracy.",
    color: "text-blue-500",
  },
  {
    icon: Handshake,
    title: "Patient Care",
    desc: "Treating every patient with respect, empathy, and the highest standards of professional service.",
    color: "text-rose-500",
  },
];

const testCategories = [
  {
    cat: "Hematology",
    tests: [
      "Complete Blood Count (CBC)",
      "ESR",
      "Peripheral Blood Smear",
      "Reticulocyte Count",
      "Coagulation Profile",
    ],
  },
  {
    cat: "Biochemistry",
    tests: [
      "Liver Function Tests",
      "Kidney Function Tests",
      "Lipid Profile",
      "Blood Sugar / HbA1c",
      "Thyroid Panel",
    ],
  },
  {
    cat: "Microbiology",
    tests: [
      "Urine Culture",
      "Blood Culture",
      "Stool Culture",
      "AFB Smear / Culture",
      "Sensitivity Testing",
    ],
  },
  {
    cat: "Serology / Immunology",
    tests: [
      "HIV, HBsAg, HCV",
      "Dengue NS1 / IgM",
      "Widal Test",
      "TORCH Profile",
      "ANA & Rheumatoid Factor",
    ],
  },
  {
    cat: "Molecular (PCR)",
    tests: [
      "COVID-19 RT-PCR",
      "HBV / HCV DNA Quantification",
      "TB-PCR",
      "HPV Genotyping",
      "Flu A/B Panel",
    ],
  },
  {
    cat: "Hormones & Endocrinology",
    tests: [
      "TSH, T3, T4",
      "FSH / LH / Prolactin",
      "Testosterone / Estradiol",
      "Cortisol",
      "Insulin Level",
    ],
  },
];
---

<Layout
  title="About Us | Mir Diagnostics"
  description="Learn about Mir Diagnostics – our mission, values, and state-of-the-art laboratory services in Pampore, Kashmir."
>
  <main id="main-content">
    <section
      class="pt-20 bg-linear-to-br from-[#0D6B3A] to-[#16A34A] text-white"
      aria-labelledby="about-hero-title"
    >
      <div class="max-w-7xl mx-auto px-4 md:px-8 py-20">
        <span
          class="font-mono text-white/60 text-sm tracking-widest uppercase block mb-3"
          >— Our Story</span
        >
        <h1
          id="about-hero-title"
          class="font-heading text-5xl md:text-6xl font-bold mb-4"
        >
          About Mir Diagnostics
        </h1>
        <p class="text-white/80 text-xl max-w-2xl leading-relaxed">
          Committed to excellence in medical diagnostics, serving the people of
          Kashmir with precision, care, and integrity.
        </p>
      </div>
    </section>

    <section class="section-padding bg-white" aria-labelledby="trust-heading">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="section-tag" aria-hidden="true">Who We Are</span>
            <h2 id="trust-heading" class="section-title">
              A Lab Built on Trust
            </h2>
            <p class="text-gray-600 leading-relaxed mt-4 mb-6">
              Founded over a decade ago, Mir Diagnostics has grown to become one
              of the most trusted diagnostic centers in the Kashmir Valley. Our
              laboratory is equipped with state-of-the-art instruments operated
              by qualified scientists and technicians who are dedicated to
              delivering accurate and timely results.
            </p>
            <p class="text-gray-600 leading-relaxed mb-8">
              We believe that access to quality diagnostic services is a
              fundamental right. That is why we strive to offer world-class
              testing at affordable prices, backed by a team of experienced
              pathologists and radiologists.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="/contact"
                class="btn-primary inline-flex items-center justify-center gap-2"
              >
                Book an Appointment <ArrowRight className="w-4 h-4" />
              </a>
              <a
                href="/doctors"
                class="btn-outline inline-flex items-center justify-center gap-2"
              >
                Meet Our Team
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {
              values.map((v) => {
                const Icon = v.icon;
                return (
                  <article class="bg-emerald-50/50 rounded-2xl p-6 border border-emerald-100 transition-transform hover:-translate-y-1">
                    <div
                      class={`w-12 h-12 rounded-xl bg-white flex items-center justify-center shadow-sm mb-4 ${v.color}`}
                    >
                      <Icon
                        className="w-6 h-6"
                        strokeWidth={2.5}
                        aria-hidden="true"
                      />
                    </div>
                    <h3 class="font-heading font-bold text-emerald-900 mb-2">
                      {v.title}
                    </h3>
                    <p class="text-gray-600 text-sm leading-relaxed">
                      {v.desc}
                    </p>
                  </article>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <section
      class="section-padding bg-emerald-50/30"
      aria-labelledby="services-heading"
    >
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="text-center mb-14">
          <span class="section-tag" aria-hidden="true">Comprehensive Care</span>
          <h2 id="services-heading" class="section-title">
            Our Laboratory Specialties
          </h2>
          <p class="section-subtitle mx-auto">
            We offer over 500 diagnostic tests across all major medical
            specialties using automated technologies.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            testCategories.map((c) => (
              <section
                class="bg-white rounded-2xl border border-emerald-100 p-7 shadow-sm hover:shadow-md transition-shadow group"
                aria-labelledby={`cat-${c.cat.replace(/\s+/g, "-").toLowerCase()}`}
              >
                <h3
                  id={`cat-${c.cat.replace(/\s+/g, "-").toLowerCase()}`}
                  class="font-heading text-xl font-bold text-emerald-900 mb-5 pb-3 border-b border-emerald-50 flex items-center justify-between"
                >
                  {c.cat}
                  <ChevronRight className="w-4 h-4 text-emerald-300 group-hover:text-emerald-500 transition-colors" />
                </h3>
                <ul
                  class="space-y-3"
                  aria-label={`Tests available in ${c.cat}`}
                >
                  {c.tests.map((t) => (
                    <li class="flex items-start gap-3 text-sm text-gray-600">
                      <span
                        class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0 mt-1.5"
                        aria-hidden="true"
                      />
                      {t}
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section-padding bg-white" aria-labelledby="cert-heading">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="text-center mb-12">
          <span class="section-tag" aria-hidden="true">Quality Assurance</span>
          <h2 id="cert-heading" class="section-title">
            Accreditations & Standards
          </h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {
            [
              "NABL Accredited",
              "ISO 15189:2022",
              "CAP Certified",
              "Govt. Empanelled",
            ].map((a) => (
              <div class="text-center p-8 bg-white rounded-2xl border border-emerald-100 hover:border-emerald-400 hover:bg-emerald-50/30 transition-all group">
                <div class="w-14 h-14 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                  <ShieldCheck
                    className="w-7 h-7 text-emerald-600"
                    strokeWidth={2}
                    aria-hidden="true"
                  />
                </div>
                <div class="font-heading font-bold text-emerald-900 text-sm tracking-tight">
                  {a}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
